{
  "id": "abasid_caliphate_04_kukosha_kwebvudzi",
  "title": "KUKOSHA KWEBVUDZI",
  "english_title": "The Importance of Hair",
  "author": "ABASID 1841",
  "compiler": "Lord Blessed Murove",
  "tradition": "Abasid",
  "language": "Shona/English",
  "date": "08/01/26",
  "collection": "THE ABASID CALIPHATE",
  "description": "Teaching from THE ABASID CALIPHATE collection: KUKOSHA KWEBVUDZI (The Importance of Hair)",
  "keywords": [
    "vhudzi",
    "hair",
    "aerial",
    "network",
    "mweya",
    "spirit",
    "frequency"
  ],
  "verse_count": 94,
  "verses": [
    {
      "verse": 1,
      "text": "4.KUKOSHA KWEBVUDZI BVUNZO: ABASID 1841 Ingave mhosva hr kunamata ndine rasta kumasowe"
    },
    {
      "verse": 2,
      "text": "ANSWER: Baba johani vakaramba"
    },
    {
      "verse": 3,
      "text": "Handina chandino bvisa pashoko ravo"
    },
    {
      "verse": 4,
      "text": "Ndino wedzera bedzi neku jekesa"
    },
    {
      "verse": 5,
      "text": "RA ☀️ Munhu wese agerwe"
    },
    {
      "verse": 6,
      "text": "Chinoitika nde ichi"
    },
    {
      "verse": 7,
      "text": "Vhudzi raka fanana ne Aerial ye radio"
    },
    {
      "verse": 8,
      "text": "Rino bata network dze mweya"
    },
    {
      "verse": 9,
      "text": "Asi kuti rizobata network zvino enderana nekuti radio yacho iwe waka chunwa kubata network ipi"
    },
    {
      "verse": 10,
      "text": "Network ino chunwa nezviito"
    },
    {
      "verse": 11,
      "text": "Ndanga ndiri kuti, vhudzi rino bata network yemu mweya"
    },
    {
      "verse": 12,
      "text": "Asi haribate network tsvene chete"
    },
    {
      "verse": 13,
      "text": "Rino bata kana Mweya wakaipa"
    },
    {
      "verse": 14,
      "text": "Kuti muzive kuti ndiri kureva idi,"
    },
    {
      "verse": 15,
      "text": "Tarisai kuti"
    },
    {
      "verse": 16,
      "text": "Ukasvika pane chipoko, vhudzi rinoti nyau nyau, iwe usina kuchiona"
    },
    {
      "verse": 17,
      "text": "Dai watanga wachiona rozoti nyau nyau, taiti radaro nekuda kwe zvawa ona"
    },
    {
      "verse": 18,
      "text": "Razviziva sei risina maziso"
    },
    {
      "verse": 19,
      "text": "Razvinzwa sei risina nzeve"
    },
    {
      "verse": 20,
      "text": "Kana ukasvika pane nyoka chaiyo rinoti nyau nyau kana kusimuka"
    },
    {
      "verse": 21,
      "text": "Yaiva suit yaka kwana pa munhu wekutanga"
    },
    {
      "verse": 22,
      "text": "Munhu wekutanga ahana kusikwa akashota"
    },
    {
      "verse": 23,
      "text": "Aitova ne zvino mutungamira paku rarama"
    },
    {
      "verse": 24,
      "text": "Nekuti Mwari aiva ma ari"
    },
    {
      "verse": 25,
      "text": "Kana hurwere kwaiva kusina"
    },
    {
      "verse": 26,
      "text": "Ndosaka pa eden pasina kusikwa zvipatara"
    },
    {
      "verse": 27,
      "text": "Nyama yaizvi rapa"
    },
    {
      "verse": 28,
      "text": "Nekuti mushonga waiva kunze waiva mucherechedzo we mushonga waiva mukati"
    },
    {
      "verse": 29,
      "text": "Hapana pawaino chera gwenzi, izvo zviri mugwenzi racho zviri mauri"
    },
    {
      "verse": 30,
      "text": "Ngirozi mumu viri dzaino chera gwenzi mumuviri dzo rapa muviri"
    },
    {
      "verse": 31,
      "text": "Ndo pane secret yeku teurira murwere achipona"
    },
    {
      "verse": 32,
      "text": "Usina kumu mwisa Gavakava"
    },
    {
      "verse": 33,
      "text": "Reku temha kunze"
    },
    {
      "verse": 34,
      "text": "Saka murapi pa ano teurira murwere, anotaura ne varapi vari mumurwere kuti mupei gavakava"
    },
    {
      "verse": 35,
      "text": "Varapi vokupa gavakava pasina aenda kuno chera ne badza"
    },
    {
      "verse": 36,
      "text": "Zvino vanhu pavakazo dzima mwari mavari nekuda kufa"
    },
    {
      "verse": 37,
      "text": "RA ☀️ Simba iroro rakapera nekuti Vakanga vafa RA ☀️ kutaura zuva kana zivo raiva mavari"
    },
    {
      "verse": 38,
      "text": "Ndo pavakanzi zano, chitemai gavakava kunze"
    },
    {
      "verse": 39,
      "text": "Dzaiva tsitsi futi"
    },
    {
      "verse": 40,
      "text": "Asi zvisirizvo zve pamavambo"
    },
    {
      "verse": 41,
      "text": "Chinonzi kupona ndo pakuno tangira"
    },
    {
      "verse": 42,
      "text": "Kana tadzokera pamavambo"
    },
    {
      "verse": 43,
      "text": "Kwete pa nevanji chete"
    },
    {
      "verse": 44,
      "text": "Ndapedza 🙏🏻🙏🏻🙏🏻 Chivhunzai henyu"
    },
    {
      "verse": 45,
      "text": "Ndipe vamwe mukana"
    },
    {
      "verse": 46,
      "text": "Vanhu vaka tyora mutemo vhudzi rino bata network isiriyo"
    },
    {
      "verse": 47,
      "text": "Munhu i radio"
    },
    {
      "verse": 48,
      "text": "Mabasa ako ndiwo"
    },
    {
      "verse": 49,
      "text": "Kana wakaipa toti wava pa frequency 96.0"
    },
    {
      "verse": 50,
      "text": "Saka arial inobata nhau dze radio 2"
    },
    {
      "verse": 51,
      "text": "Asi kana uine mabasa akanaka unenge uri pa frequency 99.3"
    },
    {
      "verse": 52,
      "text": "Saka vhudzi rako rinobatawo radio 3"
    },
    {
      "verse": 53,
      "text": "Zvino baba johani vakasvika vanhu vose vari pa frequency modulation (fm) yaiva 96.0"
    },
    {
      "verse": 54,
      "text": "Vakati network yamuri kubata sandiyo"
    },
    {
      "verse": 55,
      "text": "Vanhu vakati todi, zvikanzi bvisai ma arial ayo"
    },
    {
      "verse": 56,
      "text": "Kusvika ndazoti mava pa 99.3"
    },
    {
      "verse": 57,
      "text": "Saka vhudzi harina kuipa , rino ipiswa nemabasa,"
    },
    {
      "verse": 58,
      "text": "Ndosaka johani pamhiri akafa asina kumbobvira agera vhudzi,"
    },
    {
      "verse": 59,
      "text": "Erijah zvimwe chete, jesu zvimwe chete, samson aka dherera ndoku gera, akazo gadzikana rava kukura futi."
    },
    {
      "verse": 60,
      "text": "Jesu ahana kumbo bvira agera musoro kubva paku berekwa kusvika pakufa."
    },
    {
      "verse": 61,
      "text": "Ndozvandaka imbiswa mamurehwa"
    },
    {
      "verse": 62,
      "text": "🎶🎶🎶Munazarini wenazareta wa yeresa,🎶🎶🎶 1998 pa Endidhai"
    },
    {
      "verse": 63,
      "text": "Ma nazarene aha gere musoro"
    },
    {
      "verse": 64,
      "text": "Nekuti vano berekwa vari pa 99.3 kare"
    },
    {
      "verse": 65,
      "text": "Kana pasi razova pa 99.3"
    },
    {
      "verse": 66,
      "text": "Jehovah achauya wotiudza"
    },
    {
      "verse": 67,
      "text": "Pari zvino vhudzi pfupi pakunamata 🙏🏻 Kana magetsi ari ku pisa tv, handiti uno dembura tambo here kuti magetsi asa svike ku tv"
    },
    {
      "verse": 68,
      "text": "Ndo zvimwe chete ne vhudzi,"
    },
    {
      "verse": 69,
      "text": "Rino konector physical ne spiritual"
    },
    {
      "verse": 70,
      "text": "Kana ku spiritual kwakubva ngozi, tino dembura connection"
    },
    {
      "verse": 71,
      "text": "Nyama yombo sara yega"
    },
    {
      "verse": 72,
      "text": "Ngozi iri kwayo yega"
    },
    {
      "verse": 73,
      "text": "Totanga kugadzirisa nyama"
    },
    {
      "verse": 74,
      "text": "Kana taona kuti nyama yaita, to conecta kumagetsi tambo iya"
    },
    {
      "verse": 75,
      "text": "Nyama ika putika toti aahhh hatina kugadzira mushe"
    },
    {
      "verse": 76,
      "text": "Disconector magetsi nditraye kugadzira futi"
    },
    {
      "verse": 77,
      "text": "Hakuna munhu ano gadzira tv iri pamagetsi"
    },
    {
      "verse": 78,
      "text": "Nekuti inozo gwinha newe"
    },
    {
      "verse": 79,
      "text": "Apo uri kuyedza kuigadzira"
    },
    {
      "verse": 80,
      "text": "Saka izwi riri kugadzira nyama dzedu raka disconector magetsi"
    },
    {
      "verse": 81,
      "text": "Saka tambo ahina kuipa"
    },
    {
      "verse": 82,
      "text": "Asi ukai connector kuchinhu chakafa"
    },
    {
      "verse": 83,
      "text": "Ndaona makafa"
    },
    {
      "verse": 84,
      "text": "Ndaona vakafa vachifamba"
    },
    {
      "verse": 85,
      "text": "Muri right , handina kuti vhudzi chete"
    },
    {
      "verse": 86,
      "text": "Zvizhinji zviri mumunhu"
    },
    {
      "verse": 87,
      "text": "Ndosaka iri kuparidzwa"
    },
    {
      "verse": 88,
      "text": "Vhudzi sandiro rega rino batanidza nyika mbiri idzi"
    },
    {
      "verse": 89,
      "text": "Asi iro rakaonekwa ne muridzi achiti , harina imwe solution"
    },
    {
      "verse": 90,
      "text": "Kunze kwekumbori bvisa"
    },
    {
      "verse": 91,
      "text": "Vhudzi hari paridzike"
    },
    {
      "verse": 92,
      "text": "Asi hana ino paridzika"
    },
    {
      "verse": 93,
      "text": "Asi zvose zvino sensor 🙏🏼 Ndapedza"
    },
    {
      "verse": 94,
      "text": "Ndafunga kuti muchabvunza henyu kuti ko ndebvu"
    }
  ]
}