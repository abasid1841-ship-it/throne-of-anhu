  "verse_count": 68,
  "verses": [
    {
      "verse": 1,
      "text": "16.SHONA NDIMI 130/01/26"
    },
    {
      "verse": 2,
      "text": "Hanzi Shona ndiyo nyoka yacho,"
    },
    {
      "verse": 3,
      "text": "Saka tikasakoshesa Shona , tichagara tiri vanhu vari simple , vasingatyisi nekuti tinenge tisina humha 🐍 AMEN"
    },
    {
      "verse": 4,
      "text": "Akambotitiwo"
    },
    {
      "verse": 5,
      "text": "tinofanira kumutiwo"
    },
    {
      "verse": 6,
      "text": "🙏🏻 Parizvino NYOKA iri kumedza dzimwe NYOKA ndo ENGLISH KA"
    },
    {
      "verse": 7,
      "text": "Aberekwa ari mu SHONA anotoguma akutaura ENGLISH"
    },
    {
      "verse": 8,
      "text": "Zvino kwatiri ENGLISH mutauro we mafaro"
    },
    {
      "verse": 9,
      "text": "Ndosaka, pfambi dzinotaura ENGLISH inotyisa"
    },
    {
      "verse": 10,
      "text": "Nekuti dziri ku mutauro we mafaro"
    },
    {
      "verse": 11,
      "text": "Netsika dze mafaro"
    },
    {
      "verse": 12,
      "text": "Mapfekero emafaro"
    },
    {
      "verse": 13,
      "text": "Unonzwa vachiti kuvachena hazvina mhosva kufamba makumbo ari panze"
    },
    {
      "verse": 14,
      "text": "Kureva kuti HUNHU hwe ANHU hunenge hwamedzwa ne hunhu hwe marudzi"
    },
    {
      "verse": 15,
      "text": "Zvino hunhu huno vambira pa mutauro"
    },
    {
      "verse": 16,
      "text": "Nekuti ENGLISH ndo NDIMI kuvachena"
    },
    {
      "verse": 17,
      "text": "SHONA ndo NDIMI kuvatema"
    },
    {
      "verse": 18,
      "text": "NDIMI chaiyo chaiyo"
    },
    {
      "verse": 19,
      "text": "NDIRI KUTOTI"
    },
    {
      "verse": 20,
      "text": "Mutauro uchinzi"
    },
    {
      "verse": 21,
      "text": "IYESU CHAIYE"
    },
    {
      "verse": 22,
      "text": "IYESU KRISTU"
    },
    {
      "verse": 23,
      "text": "MWARI ari muna ANI na ANI tose"
    },
    {
      "verse": 24,
      "text": "Saka chinonzi JESU sandi munhu mumwe chete"
    },
    {
      "verse": 25,
      "text": "Pari kutaurwa"
    },
    {
      "verse": 26,
      "text": "IYESU tose tisina"
    },
    {
      "verse": 27,
      "text": "RA ☀️ Matiri"
    },
    {
      "verse": 28,
      "text": "Kumuka kwa IYESU kunovamba neku muka kwe mutauro Wa"
    },
    {
      "verse": 29,
      "text": "Unozova tsvimbo ne chaedza cha IYESU pakufamba"
    },
    {
      "verse": 30,
      "text": "Hatisi kuzo mira kusvikira"
    },
    {
      "verse": 31,
      "text": "yedu TSVIMBO yamedza marudzi"
    },
    {
      "verse": 32,
      "text": "Kusvikira Mwana Wemu ENGLISH ati handinga ndisinga gone SHONA"
    },
    {
      "verse": 33,
      "text": "Kana achida musikana wechi ENGLISH anotiwo regai ndi nyatsomu endera ne SHONA"
    },
    {
      "verse": 34,
      "text": "Azive kuti ndino gona SHONA"
    },
    {
      "verse": 35,
      "text": "Mukomana wechi ENGLISH achiti ku Musikana wechi ENGLISH,"
    },
    {
      "verse": 36,
      "text": "makadiiko Amai vangu"
    },
    {
      "verse": 37,
      "text": "Musikana achi pindurawo,"
    },
    {
      "verse": 38,
      "text": "Ndekuno munhu wa MWARI"
    },
    {
      "verse": 39,
      "text": "Isu vatema tisipo"
    },
    {
      "verse": 40,
      "text": "Se zvamunoita imi Samaita vachiti WHATS UP GIRL kuba CHIHERA"
    },
    {
      "verse": 41,
      "text": "Chihera opindurawo achiti"
    },
    {
      "verse": 42,
      "text": "NOTHING , just chilling"
    },
    {
      "verse": 43,
      "text": "Pasina mu ENGLISH ipapo"
    },
    {
      "verse": 44,
      "text": "Ndo zvino ratidza kuti vachena vachiri"
    },
    {
      "verse": 45,
      "text": "Zvino akambotitiwo"
    },
    {
      "verse": 46,
      "text": "tichamutiwo"
    },
    {
      "verse": 47,
      "text": "Iiiii sa ka"
    },
    {
      "verse": 48,
      "text": "vanofanira kuti vakati ona"
    },
    {
      "verse": 49,
      "text": "Ndo munembo pa mhanza"
    },
    {
      "verse": 50,
      "text": "RUPAWO rwe ropa re HWAI"
    },
    {
      "verse": 51,
      "text": "Zvino vamba neku mutsa mutauro wedu"
    },
    {
      "verse": 52,
      "text": "Nekuti ndiwo wega nzira yekutaura nayo na MWARI wedu"
    },
    {
      "verse": 53,
      "text": "Hakuna RUDZI rwusina kupihwa TSVIMBO"
    },
    {
      "verse": 54,
      "text": "Hakuna musha usina TSVIMBO ye musiranwa"
    },
    {
      "verse": 55,
      "text": "TSVIMBO yekwa nhingi hainga yambutse iwe"
    },
    {
      "verse": 56,
      "text": "Saka isu hati yambutswe ne TSVIMBO ye va ENGLISH"
    },
    {
      "verse": 57,
      "text": "Ndeye musha wavo"
    },
    {
      "verse": 58,
      "text": "Yakanaka ikoko kwete kuno"
    },
    {
      "verse": 59,
      "text": "Neyedu yakanaka kuno kwete kwavo"
    },
    {
      "verse": 60,
      "text": "Ndosaka vachiti chi RA hachizi Mwari wedu , chi MWARI chezuva cheku EGYPT"
    },
    {
      "verse": 61,
      "text": "Kwavari ndiri CHI MWARI chekuno"
    },
    {
      "verse": 62,
      "text": "Nemiwo itaiwo kune chavo , kuti CHI MWARI che vachena"
    },
    {
      "verse": 63,
      "text": "Chakauya chaka uraya Mbuya Nehanda asina mhaka"
    },
    {
      "verse": 64,
      "text": "Chika manikidza SEKURU Kaguvi kuti ndinamate"
    },
    {
      "verse": 65,
      "text": "Ukasa bhabhatidzwa ku ROMA unofa usina kuona Mwana wako musikana"
    },
    {
      "verse": 66,
      "text": "Ndokubva ati chindi bhabhatidzai ndimuone keku pedzisira"
    },
    {
      "verse": 67,
      "text": "Moti Ndi MWARI wedu iyeye"
    },
    {
      "verse": 68,
      "text": "Ndatenda 🙏🏼☀️"
    }
  ]
}