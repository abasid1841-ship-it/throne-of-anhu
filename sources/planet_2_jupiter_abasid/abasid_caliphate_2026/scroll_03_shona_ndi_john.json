      "text": "zvareva kuti"
    },
    {
      "verse": 92,
      "text": "Iiiii SA KA"
    },
    {
      "verse": 93,
      "text": "Nepatasvika apa"
    },
    {
      "verse": 94,
      "text": "Takuziva kuti"
    },
    {
      "verse": 95,
      "text": "Kusave PAUL"
    },
    {
      "verse": 96,
      "text": "Kusave PAUL"
    },
    {
      "verse": 97,
      "text": "kana kuri PAUL"
    },
    {
      "verse": 98,
      "text": "kwatova PAUL"
    },
    {
      "verse": 99,
      "text": "Kana muri PO"
    },
    {
      "verse": 100,
      "text": "Hamungave PO"
    },
    {
      "verse": 101,
      "text": "Nezuro maiva SO"
    },
    {
      "verse": 102,
      "text": "Ndiri kungoti"
    },
    {
      "verse": 103,
      "text": "Kupenya kugare munemi"
    },
    {
      "verse": 104,
      "text": "GOD IS EXISTENCE"
    },
    {
      "verse": 105,
      "text": "Kuvepo kwedu chete ndo Mwari iyeye"
    },
    {
      "verse": 106,
      "text": "ari huve PO"
    },
    {
      "verse": 107,
      "text": "tava kugona here kuchiti"
    },
    {
      "verse": 108,
      "text": "Kune ari PO,"
    },
    {
      "verse": 109,
      "text": "Aiva muna ari PO,"
    },
    {
      "verse": 110,
