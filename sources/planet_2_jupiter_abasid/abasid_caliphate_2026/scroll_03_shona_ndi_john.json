    },
    {
      "verse": 76,
      "text": "Nhau yedu yava kuchifamba manje"
    },
    {
      "verse": 77,
      "text": "Kuti munhu uparidze IDI panhau ya MWARI uchiratidza kuti UNOZIVA asi Hauzive zvese unoti"
    },
    {
      "verse": 78,
      "text": "TAKAFUNDA KUTI"
    },
    {
      "verse": 79,
      "text": "Kuna MWARI,"
    },
    {
      "verse": 80,
      "text": "aiva ma ari."
    },
    {
      "verse": 81,
      "text": "Rataona kuti tikamupa, akati vhunza kuti sei mandipa zita rekuti HAMENO,"
    },
    {
      "verse": 82,
      "text": "tinongo mutiwo"
    },
    {
      "verse": 83,
      "text": "Zva kwa ari kuti ari tambire"
    },
    {
      "verse": 84,
      "text": "Nyangwe iye akasari daira, isu tinori shandisa pakutaura ne zvake"
    },
    {
      "verse": 85,
      "text": "Ndokuti ukaramba nickname ndo paino pfumbira"
    },
    {
      "verse": 86,
      "text": "Isu hatimuzive Mwari zvizere"
    },
    {
      "verse": 87,
      "text": "Mazita ose aano pihwa hationi ari ake"
    },
    {
      "verse": 88,
      "text": "Zita ratinonzwa muma tsamba anoti"
    },
    {
      "verse": 89,
      "text": "hakungave PO"
    },
    {
      "verse": 90,
      "text": "Hapana kusave PO"
    },
