    },
    {
      "verse": 111,
      "text": "Ndo akazonzi ne vachena AMEN"
    },
    {
      "verse": 112,
      "text": "Vara rekuti AMEN rakabva mu SHONA kuti AMENO,"
    },
    {
      "verse": 113,
      "text": "Mirai kuramba"
    },
    {
      "verse": 114,
      "text": "Ndatoona kuti makada kumhanya"
    },
    {
      "verse": 115,
      "text": "Nyorai pa GOOGLE muti"
    },
    {
      "verse": 116,
      "text": "AMEN zvinoreva kuti chiyi ku ANCIENT EGYPT"
    },
    {
      "verse": 117,
      "text": "What does AMEN mean in ANCIENT EGYPT"
    },
    {
      "verse": 118,
      "text": "🙏 Ah, AMEN! Ku Ancient Egypt, AMEN zvinoreva \"hidden one\" or \"the hidden god\". Zvinonongedzera kuna Amun, god of the wind and fertility."
    },
    {
      "verse": 119,
      "text": "Zviri kungonzi"
    },
    {
      "verse": 120,
      "text": "Nekuti chinhu chausinga zive chakafanana nekuti chaka vanzika"
    },
    {
      "verse": 121,
      "text": "Pataiva ku EGYPT"
    },
    {
      "verse": 122,
      "text": "ndini ndakati"
    },
    {
      "verse": 123,
      "text": "Kana kuti AMENO"
    },
    {
      "verse": 124,
      "text": "Kana tapedza kunamata ,tose tino fanira kuti"
    },
    {
      "verse": 125,
      "text": "Nekuti hatizive kuti unodairwa here kana kuti kwete"
    },
    {
      "verse": 126,
      "text": "Hakuna izwi rakafamba risiri irori ra Baba Johani"
    },
    {
      "verse": 127,
      "text": "Irori izwi ratinaro ndo IZWI ra MWARI mu AFRICA"
    },
    {
      "verse": 128,
      "text": "Ripiko JOHANI ka"
    },
    {
      "verse": 129,
      "text": "Saka pamwe hamuna kundinzwa zuva riya"
    },
    {
      "verse": 130,
      "text": "Endai pa GOOGLE moti"
    },
    {
      "verse": 131,
      "text": "SHONA meaning in HEBREW"
    },
    {
      "verse": 132,
      "text": "Zviri kunzi Muchi HEBREW"
    },
    {
      "verse": 133,
      "text": "SHONA zvinoreva kuti chiyi apo??"
    },
    {
      "verse": 134,
      "text": "In Hebrew, the name Shona is a feminine form of John (Yochanan), meaning \"God is gracious\" or \"Yahweh is gracious,\" though it also has Scottish Gaelic roots as a diminutive of Janet/Joan. It can also mean \"grace\" or \"charm,\" and it's the name of a major ethnic group in Zimbabwe, with no direct Hebrew translation for the people/language itself."
    },
    {
      "verse": 135,
      "text": "Ndo pane nhau yese apa"
    },
    {
      "verse": 136,
      "text": "Ukaona wabvuma apa ,"
    },
    {
      "verse": 137,
      "text": "Ndo pano vambira RUPONESO"
    },
    {
      "verse": 138,
      "text": "Chino ponesa TSITSI"
    },
    {
      "verse": 139,
      "text": "Shona zvinoreva kuti"
    },
    {
      "verse": 140,
      "text": "TSITSI dza MWARI"
    },
    {
      "verse": 141,
      "text": "MWARI vane TSITSI"
    },
    {
      "verse": 142,
      "text": "GOD IS GRACIOUS"
    },
    {
      "verse": 143,
      "text": "Hatisi kutaura ropa kana dzinza rema SHONA pari zvino"
    },
    {
      "verse": 144,
      "text": "Tiri kutaura language bedzi"
    },
    {
      "verse": 145,
      "text": "Ingave ichitaurwa nemu zulu"
    },
    {
      "verse": 146,
      "text": "Kana mu nijerian"
    },
    {
      "verse": 147,
      "text": "Mutauro iwowo we SHONA ndo IZWI ra MWARI mu AFRICA"
    },
    {
      "verse": 148,
      "text": "Nekuti MUCHI"
    },
    {
      "verse": 149,
      "text": "Hebrew unogona kuti SHONA kana JOHANI"
    },
    {
      "verse": 150,
      "text": "Hamusi kundinzwa neiko"
    },
    {
      "verse": 151,
      "text": "IZWI raidanidzira murenje raiva izwi re SHONA"
    },
    {
      "verse": 152,
      "text": "Mutauro we SHONA ndo unotanga kuuya kana MWARI ava kubva pahasha kuenda pa nyasha"
    },
    {
      "verse": 153,
      "text": "Pasi rose raito ziva kuti tikaona vaye vano paridza ne shona vamuka toziva kuti nyasha dzava mupasi"
    },
    {
      "verse": 154,
      "text": "Kana Mwari aka gumbuka Shona inenge yaka nyarara"
    },
    {
      "verse": 155,
      "text": "Muchitaura henyu asi musina simba"
    },
    {
      "verse": 156,
      "text": "Kana MWARI azonzwa tsitsi ano mutsa SHONA"
    },
    {
      "verse": 157,
      "text": "Isu tobva tatanga kufunda shona, tobva taona kuti ahhhh inga nzira yekupona iri mumutauro wedu"
    },
    {
      "verse": 158,
      "text": "Tanga tichi tsvaga chinhu chatagara tinacho"
    },
    {
      "verse": 159,
      "text": "Mune muvhunzo here"
    },
    {
      "verse": 160,
      "text": "Panhau yekuti"
    },
    {
      "verse": 161,
      "text": "SHONA ndo IZWI JOHANI"
    },
    {
      "verse": 162,
      "text": "Muchi wirirana neni"
    },
    {
      "verse": 163,
      "text": "ndozoku ratidzai kuti sei"
    },
    {
      "verse": 164,
      "text": "GOD IS GRACIOUS"
    },
    {
      "verse": 165,
      "text": "GOD IS GRACIOUS"
    },
    {
      "verse": 166,
      "text": "SHONA = JOHN"
    },
    {
      "verse": 167,
      "text": "Zvataita nhasi"
    },
    {
      "verse": 168,
      "text": "Taziva kuti kuti MWARI"
    },
    {
      "verse": 169,
      "text": "Mazita ose ana PIO , BABA, JEHOVAH zvibatiso bedzi, asi iye pachake ahana ZITA"
    },
    {
      "verse": 170,
      "text": "NDIRI ZVA NDIRI"
    },
    {
      "verse": 171,
      "text": "Kuti mubate mushe nhau ye zita iri"
    },
    {
      "verse": 172,
      "text": "Funga kuti uka vhunza munhu kuti nhai"
    },
    {
      "verse": 173,
      "text": "Iye obva apindura achiti"
    },
    {
      "verse": 174,
      "text": "NDIRI ZVA NDIRI"
    },
    {
      "verse": 175,
      "text": "Ahasi kuti usandibvunze here apo?"
    },
    {
      "verse": 176,
      "text": "Moses aka pindurwa izvozvo"
    },
    {
      "verse": 177,
      "text": "Ndiri wa Ndiri"
    },
    {
      "verse": 178,
      "text": "Ini handisi type ine zita"
    },
    {
      "verse": 179,
      "text": "Chingoita zva NDIRI"
    },
    {
      "verse": 180,
      "text": "Go and get them out"
    },
    {
      "verse": 181,
      "text": "Va ISRAEL vauri kuti vachaku vhunza kuti watumwa nani"
    },
    {
      "verse": 182,
      "text": "Uva pindure kuti"
    },
    {
      "verse": 183,
      "text": "Who is speaking?"
    },
    {
      "verse": 184,
      "text": "Ini ndikati"
    },
    {
      "verse": 185,
      "text": "BVUNZO: Zvinoreva kuti ndati ndi ANI ari kutaura?"
    },
    {
      "verse": 186,
      "text": "MHINDURO: Ndimi muri kutaura"
    },
    {
      "verse": 187,
      "text": "Who sent you?"
    },
    {
      "verse": 188,
      "text": "Ini ndika pindura ndichiti"
    },
    {
      "verse": 189,
      "text": "BVUNZO: I AM"
    },
    {
      "verse": 190,
      "text": "has sent me."
    },
    {
      "verse": 191,
      "text": "Ndiri kuti ndatumwa"
    },
    {
      "verse": 192,
      "text": "MHUNDURO: Ndimi mazvituma"
    },
    {
      "verse": 193,
      "text": "aka dzorera SIMBA rake kuna MOSES"
    },
    {
      "verse": 194,
      "text": "MOSES akaziva ka"
    },
    {
      "verse": 195,
      "text": "Kana MWARI ka"
    },
    {
      "verse": 196,
      "text": "Zva ari kuita ka"
    },
    {
      "verse": 197,
      "text": "Ndi Mwari Ka"
    },
    {
      "verse": 198,
      "text": "Ari kuzvi ita ka"
    },
    {
      "verse": 199,
      "text": "Mwari anoda kuti uzive kuti iwe ndiye, poshi"
    },
    {
      "verse": 200,
      "text": "Shona ndi Johane"
    },
    {
      "verse": 201,
      "text": "Ahasi uko kana apa"
    },
    {
      "verse": 202,
      "text": "Tenzi Jesu vaka vhunzwa neva FARISI"
    },
    {
      "verse": 203,
      "text": "vakanzi Ko MWARI aripi?"
    },
    {
      "verse": 204,
      "text": "Vaka pindura vachiti"
    },
    {
      "verse": 205,
      "text": "Humambo hwa MWARI huri ma uri"
    },
    {
      "verse": 206,
      "text": "Moses akatongo svika kuva ISRAEL vari kuma FARO,"
    },
    {
      "verse": 207,
      "text": "Ibvai kuma FARO tiende ku renje"
    },
    {
      "verse": 208,
      "text": "Va ISRAEL vakati watumwa nani kuzoti bvisa kuma FARO"
    },
    {
      "verse": 209,
      "text": "Moses akati"
    },
    {
      "verse": 210,
      "text": "Akanga apihwa authority na MWARI ka"
    },
    {
      "verse": 211,
      "text": "Kuti zvawava kuziva kuti"
    },
    {
      "verse": 212,
      "text": "Chivaudza zvauri kuda,"
    },
    {
      "verse": 213,
      "text": "Zvauri kuda"
    },
    {
      "verse": 214,
      "text": "Zvandiri kuda"
    },
    {
      "verse": 215,
      "text": "Zvausiri kuda"
    },
    {
      "verse": 216,
      "text": "Zvandisiri kuda"
    },
    {
      "verse": 217,
      "text": "Ndo muchato wekutanga unoitwa pakati pako ne akaku sika"
    },
    {
      "verse": 218,
      "text": "Mwari akasikira munhu kuti iye ararame se munhu"
    },
    {
      "verse": 219,
      "text": "Kureva kuti panonzi ipa hupenyu hwako kuna Mwari , zviri kungonzi"
    },
    {
      "verse": 220,
      "text": "Ibva pakuzvi ita uri kurarama"
    },
    {
      "verse": 221,
      "text": "Ita Mwari ari kurarama"
    },
    {
      "verse": 222,
      "text": "Kana wadaro uchaona kuti uchati"
    },
    {
      "verse": 223,
      "text": "Chirwere ibva"
    },
    {
      "verse": 224,
      "text": "Chobva chabva"
    },
    {
      "verse": 225,
      "text": "Shumba ne mhuka zvichakutya"
    },
    {
      "verse": 226,
      "text": "Kwete kukudya"
    },
    {
      "verse": 227,
      "text": "Nhamo nema tambudziko zvicha kutya"
    },
    {
      "verse": 228,
      "text": "Kwete kukudya"
    },
    {
      "verse": 229,
      "text": "Ucharova gungwa mvura ichi patsuka"
    },
    {
      "verse": 230,
      "text": "Ucha taura ne makomo kuti ibvai munzira achibva"
    },
    {
      "verse": 231,
      "text": "Iiiiii sa ka"
    },
    {
      "verse": 232,
      "text": "Chakapa kuti MOSES aite minana inhau yekuti"
    },
    {
      "verse": 233,
      "text": "Aiti ndini ndazviita"
    },
    {
      "verse": 234,
      "text": "Mwari anoda munhu anotenda kuti ndinogona kutaura ne mvura ikandi terera"
    },
    {
      "verse": 235,
      "text": "Ndo zvakazikanwa nevaporofiti venyu ku masowe"
    },
    {
      "verse": 236,
      "text": "Zvavasinga taure"
    },
    {
      "verse": 237,
      "text": "Dambudziko bedzi"
    },
    {
      "verse": 238,
      "text": "Vamwe vakashandisa zivo iroro kusika matambudziko mu vanhu"
    },
    {
      "verse": 239,
      "text": "Saka vanoti ukasamupa mari,"
    },
    {
      "verse": 240,
      "text": "Anongo simuka oti"
    },
    {
      "verse": 241,
      "text": "Baba ndanzi muchaita tsaona"
    },
    {
      "verse": 242,
      "text": "Saka muno fanira kudai"
    },
    {
      "verse": 243,
      "text": "Iwe ukasadaro zvedi tsaona ino itika"
    },
    {
      "verse": 244,
      "text": "Asi tsaona yaisavapo asati ataura"
    },
    {
      "verse": 245,
      "text": "Tsaona yasikwa ne muporofiti"
    },
    {
      "verse": 246,
      "text": "Mhosva dzavacha rasirwa"
    },
    {
      "verse": 247,
      "text": "Tarisisa tarisisa"
    },
    {
      "verse": 248,
      "text": "Ukanetsana ne muporofiti"
    },
    {
      "verse": 249,
      "text": "Anotanga kukupa tsananguro dze rufu"
    },
    {
      "verse": 250,
      "text": "Nekuti MWARI akapa munhu simba rekusika nekutaura"
    },
    {
      "verse": 251,
      "text": "JEHOVAH wakanditi"
    },
    {
      "verse": 252,
      "text": "Vaporofiti havacha fanira ku porofita dambudziko"
    },
    {
      "verse": 253,
      "text": "Vanofanira kubvisa dambudziko"
    },
    {
      "verse": 254,
      "text": "Vasina kuku udza"
    },
    {
      "verse": 255,
      "text": "Ano ku udzirei chinhu cha agara atumwa kuzobvisa"
    },
    {
      "verse": 256,
      "text": "Baba ndaona marwara"
    },
    {
      "verse": 257,
      "text": "Asi munofanira kuzodai kuti musa rware"
    },
    {
      "verse": 258,
      "text": "Wadi kutangira pakuti Baba ndanzi muzodai"
    },
    {
      "verse": 259,
      "text": "Munhu oramba kana kubvuma kuzviita"
    },
    {
      "verse": 260,
      "text": "Dambudziko haritaurwe rino bviswa"
    },
    {
      "verse": 261,
      "text": "BVUNZO :Jesu akambo porofita dambudziko remunhu ozori bvisa here???"
    },
    {
      "verse": 262,
      "text": "Hongu kana kwete"
    },
    {
      "verse": 263,
      "text": "ANSWER: Kwete"
    },
    {
      "verse": 264,
      "text": "Ndosaka ndichiti muchandiramba mose"
    },
    {
      "verse": 265,
      "text": "Kana imi ABASID 1841 zvatai namata tese makatanga 1993 kuporofita matambudziko muchipa kundiso"
    },
    {
      "verse": 266,
      "text": "Nhasi mava kuti HAZVI FANIRE kudaro"
    },
    {
      "verse": 267,
      "text": "Aisava Mwari we IDI here aitaura muva porofiti???"
    },
    {
      "verse": 268,
      "text": "Mhinduro inoti"
    },
    {
      "verse": 269,
      "text": "MBERI kwa EMANUEL kuno uya JOHANI"
    },
    {
      "verse": 270,
      "text": "Johani ari ano tendeutsa vanhu vaka tarisa kusiriko achivati ayewa , imi mukaramba maka tarisa uko, paku uya kwa EMANUEL hamungazo muoni"
    },
    {
      "verse": 271,
      "text": "Nekuti ahasi kuuya ne kwamaka tarisa"
    },
    {
      "verse": 272,
      "text": "Mutarise kwamabva"
    },
    {
      "verse": 273,
      "text": "Nekuti kwamuri kubva ndokwa ari kuuya nakwo"
    },
    {
      "verse": 274,
      "text": "Kwete kwa muri kuenda uko"
    },
    {
      "verse": 275,
      "text": "Paisa taurwa kutendeuka kwe miviri yevanhu asi kutendeuka kwe tsika dze vanhu"
    },
    {
      "verse": 276,
      "text": "Vachi dzokera kutsika dze kwavakabva"
    },
    {
      "verse": 277,
      "text": "Vanhu vakabvepi , vanhu vakabva kuna MWARI"
    },
    {
      "verse": 278,
      "text": "Jesu anobvepi Anobva kuna Mwari"
    },
    {
      "verse": 279,
      "text": "Jesu zvino taura mununuri"
    },
    {
      "verse": 280,
      "text": "Zvino mununuri ahanga tange , nekuti anenge achiti kwandiri kuinda hakuna munhu saka ndiri kuno nunura Ani"
    },
    {
      "verse": 281,
      "text": "Kureva kuti vanhu ndivo vanotanga kubva kuna MWARI"
    },
    {
      "verse": 282,
      "text": "Mununuri ozo tevera ari shure kwavo"
    },
    {
      "verse": 283,
      "text": "Achiti ndiri kuno nunura avoooo"
    },
    {
      "verse": 284,
      "text": "Zvino vanhu zvavakabva kuna Mwari , pfungwa dzavo dzakanga dzisisa cheuka kwadzabva"
    },
    {
      "verse": 285,
      "text": "Vakanga vakungoti pamberi ne kwatiri kuenda"
    },
    {
      "verse": 286,
      "text": "Pasi ne kwatiri kubva"
    },
    {
      "verse": 287,
      "text": "Baba JOHANI ndokusvikova misa achiti"
    },
    {
      "verse": 288,
      "text": "Pasi ne kwamuri kuenda uko"
    },
    {
      "verse": 289,
      "text": "Pamberi nekwamuri kubva"
    },
    {
      "verse": 290,
      "text": "Muchi dimbu i kumbira U-TURN"
    },
    {
      "verse": 291,
      "text": "Vanhu vakanga vakuenda kuno uraya"
    },
    {
      "verse": 292,
      "text": "Asinga funge kuti zvakanzi kudi kwandinobva , pamusoro peku uraya"
    },
    {
      "verse": 293,
      "text": "Vamwe vakadaira"
    },
    {
      "verse": 294,
      "text": "Vamwe havana kudaira"
    },
    {
      "verse": 295,
      "text": "Vakaramba vachiti PAMBERI ne kumberi kwatiri kuenda"
    },
    {
      "verse": 296,
      "text": "Ivavo vakaramba ndo vachano ona zviri mberi kwavari kumhanyira"
    },
    {
      "verse": 297,
      "text": "Mberi kwavo kune gomba rakadzama"
    },
    {
      "verse": 298,
      "text": "Mberi kwavo kune kufa"
    },
    {
      "verse": 299,
      "text": "Kufa kufa kufa"
    },
    {
      "verse": 300,
      "text": "Ikoko hakuna anodzoka zvazvino"
    },
    {
      "verse": 301,
      "text": "Vamwe vanozo gona kuburitswa mugomba iroro after 2000 years"
    },
    {
      "verse": 302,
      "text": "Ndo vaye vari nani"
    },
    {
      "verse": 303,
      "text": "Mutongo we jeri unoenderana ne hukuru hwe mhaka"
    },
    {
      "verse": 304,
      "text": "Vamwe vanonzi life in prison"
    },
    {
      "verse": 305,
      "text": "ASI mutongo wa Mwari unotangira pa around 2000 years"
    },
    {
      "verse": 306,
      "text": "Vakaipa vamuri kuona nhasi vaine ma billion emari asi vasiri vatsvene, munogaro zvivhunza kuti ko uyu sei asina nhamo asi ahasi mutsvene"
    },
    {
      "verse": 307,
      "text": "Sei Akaipa aha rwarirwe"
    },
    {
      "verse": 308,
      "text": "Ahahatambudzike"
    },
    {
      "verse": 309,
      "text": "Imbinga mu mashoko enyu"
    },
    {
      "verse": 310,
      "text": "Sei MWARI achimusiya akadaro"
    },
    {
      "verse": 311,
      "text": "Asi ini ndiri kunamata , ndichidzoka kumba Mwana arwara"
    },
    {
      "verse": 312,
      "text": "Ndikati ndichengetewo huku, dzinofuma dzakangofa ne karwere kanozonzi kakanga kasiko, dzako huku ndodzatoti zivisa kuti kwane chirwere ichi"
    },
    {
      "verse": 313,
      "text": "Vose vamuri kuona ava, vanongo mutswa nguva pfupi pano mutswa satan nguva pfupi"
    },
    {
      "verse": 314,
      "text": "Every 2000 years Mwari anotuma mununuri"
    },
    {
      "verse": 315,
      "text": "6000 years ago"
    },
    {
      "verse": 316,
      "text": "1.ADAM , vose ana ENOCH , NOAH vaiva mu mbiri ya ADAM"
    },
    {
      "verse": 317,
      "text": "4000 years ago"
    },
    {
      "verse": 318,
      "text": "ABRAHAM, vose ana MOSES , ERIJAH, DAVID ne vamwe vaive mu mbiri ya ABRAHAM"
    },
    {
      "verse": 319,
      "text": "2000 years ago"
    },
    {
      "verse": 320,
      "text": "JESU, vose vapositori vaiva mu mbiri inonzi JESU, saka vaiti nezita ra JESU"
    },
    {
      "verse": 321,
      "text": "Iiiiii sa ka"
    },
    {
      "verse": 322,
      "text": "Tavapano kubva 1914"
    },
    {
      "verse": 323,
      "text": "Abraham akasvika vanhu vari mu mbiri ya ADAM, akati imi vari mu mbiri ya ADAM ndanzi TENDEUKAI"
    },
    {
      "verse": 324,
      "text": "Aitaura nana Baba vake ne vamwe"
    },
    {
      "verse": 325,
      "text": "Vazhinji vakaramba vachienda mberi kwavaida"
    },
    {
      "verse": 326,
      "text": "Ndo pamunonzwa kuti MWARI akati ABRAHAM ibvai uku muende uku , kunova kune nyika yandichakupai"
    },
    {
      "verse": 327,
      "text": "Yaiva nhau yeku tendeuka kutarisa ku CANAAN"
    },
    {
      "verse": 328,
      "text": "Promised land"
    },
    {
      "verse": 329,
      "text": "Nyika ye chipikirwa"
    },
    {
      "verse": 330,
      "text": "Yaiva mufananidzo weku dzokera kuna MWARI"
    },
    {
      "verse": 331,
      "text": "Zvediwo ana roti nana Sarah vakabvuma kutevera ABRAHAM"
    },
    {
      "verse": 332,
      "text": "Kutaura kuti vaka tendeuka"
    },
    {
      "verse": 333,
      "text": "Ndokuenda ku Canaan , nyika ye huchi ne mukaka"
    },
    {
      "verse": 334,
      "text": "Ndokuberekwa kwana isaka"
    },
    {
      "verse": 335,
      "text": "Vari mu huchi ne mukaka"
    },
    {
      "verse": 336,
      "text": "Ndo kuberekwa kwana jokopo"
    },
    {
      "verse": 337,
      "text": "Vari mu huchi ne mukaka"
    },
    {
      "verse": 338,
      "text": "Ndokuberekwa kwe gumi nevairi dzimba dza Israel , vari mu huchi ne mukaka"
    },
    {
      "verse": 339,
      "text": "Kuvarairwa ndoku uya"
    },
    {
      "verse": 340,
      "text": "Mweya we shanje"
    },
    {
      "verse": 341,
      "text": "Pakati pavo"
    },
    {
      "verse": 342,
      "text": "Ndoku dzinga/tengesa muninina wavo Joseph"
    },
    {
      "verse": 343,
      "text": "Vachiti ngaabve muno"
    },
    {
      "verse": 344,
      "text": "Havana kuziva kuti Nyika yavaidada nayo , yaiva nyika ya MWARI kwete yavo"
    },
    {
      "verse": 345,
      "text": "Nyika iyoyo yaiva ne huchi ne mukaka nekuda kwekuti MWARI aivemo"
    },
    {
      "verse": 346,
      "text": "Pavaka tengesa JOSEPHA, havana kuziva kuti vatengesa MWARI"
    },
    {
      "verse": 347,
      "text": "Iiiii sa ka"
    },
    {
      "verse": 348,
      "text": "Kubuda kwakaita JOSEPHA nzara yakazo sara youya"
    },
    {
      "verse": 349,
      "text": "Zvekuti CANAAN HUCHI zvakanga zvoshaya basa"
    },
    {
      "verse": 350,
      "text": "Nekuti HUCHI hwakanga hwaenda na JOSEPHA aina Mwari"
    },
    {
      "verse": 351,
      "text": "Zvekuti CANAAN MUKAKA zvakanga zvoshaya basa nekuti MUKAKA wakanga waenda JOSEPHA aina MWARI"
    },
    {
      "verse": 352,
      "text": "Kana uka tengesa mota,"
    },
    {
      "verse": 353,
      "text": "Mota iyoyo mangwana inenge iri yani?"
    },
    {
      "verse": 354,
      "text": "Good JOSEPHA akatengeswa kuva ISHMAEL , ndokubva ava wavo, na MWARI akabva ava wavo, Ma ISHMAEL havana kuziva zvavakanga vatenga, ndokubva vati"
    },
    {
      "verse": 355,
      "text": "ayewa , isu tamutenga dhora handei tinomu tengesa 10 dhoras ku EGYPT"
    },
    {
      "verse": 356,
      "text": "Pharoah ndoku tenga JOSEPHA"
    },
    {
      "verse": 357,
      "text": "Faro akabva arotswa na Mwari , hope dzakazo tsanangurwa na JOSEPHA"
    },
    {
      "verse": 358,
      "text": "Pharoah ndokuziva kuti ndakatenga MWARI"
    },
    {
      "verse": 359,
      "text": "Saka MWARI ava wangu nekuti ndini ndakamutenga"
    },
    {
      "verse": 360,
      "text": "Zvediwo akanga atenga MWARI"
    },
    {
      "verse": 361,
      "text": "Chinonzi ku TENGA"
    },
    {
      "verse": 362,
      "text": "Kureva humambo"
    },
    {
      "verse": 363,
      "text": "Paunoti nda TENGA chinhu , zvino reva kuti ndiwe wava pa DENGA racho"
    },
    {
      "verse": 364,
      "text": "PA MUSORO pacho"
    },
    {
      "verse": 365,
      "text": "Unoita zvaunoda nacho"
    },
    {
      "verse": 366,
      "text": "Vara rekuti ku TENGA, rinongo reva kuti ndiwe wava PAMUSORO PACHO"
    },
    {
      "verse": 367,
      "text": "Uka TENGA chingwa ,"
    },
    {
      "verse": 368,
      "text": "Anenge ATENGESA anoti"
    },
    {
      "verse": 369,
      "text": "Ooooooooi 🍞 MATENGAAAA"
    },
    {
      "verse": 370,
      "text": "Ma Judah va tengesa JESU kuva ROMA,"
    },
    {
      "verse": 371,
      "text": "Ndopavakati ku ROME"
    },
    {
      "verse": 372,
      "text": "Oooooooi ✝️ MATENGAAAAAA"
    },
    {
      "verse": 373,
      "text": "Zveshuwawo ROME yakabva yava PAMUSORO pe vanhu vose"
    },
    {
      "verse": 374,
      "text": "Nekuti yakanga yatenga JESU kuna JUDAH"
    },
    {
      "verse": 375,
      "text": "Asi JESU akati ndatengeswa kuva ROMA kwe 2000 years bedzi"
    },
    {
      "verse": 376,
      "text": "Mushure me 2000 years kubva pavatenga,"
    },
    {
      "verse": 377,
      "text": "Ndichange ndisisiri WAVO"
    },
    {
      "verse": 378,
      "text": "2000 years dzacho ndo dzazo kwana 1914"
    },
    {
      "verse": 379,
      "text": "Ndipeiwo JOHN 1 verse 11 to 14 Ye SHONA"
    },
    {
      "verse": 380,
      "text": "Nyorai kana pa META padenga apo"
    },
    {
      "verse": 381,
      "text": "Akauya kune vake, asi vake havana kumugamuchira."
    },
    {
      "verse": 382,
      "text": "Asi vose vakamugamuchira, avo vanotenda muzita rake, akavapa simba rokuva vana vaMwari."
    },
    {
      "verse": 383,
      "text": "avo vakaberekwa, kusiri kweropa, kana kwekuda kwenyama, kana kwekuda kwomurume, asi kwaMwari."
    },
    {
      "verse": 384,
      "text": "Shoko rakazova nyama, akagara pakati pedu, uye takaona kubwinya kwake, kubwinya sokwemwanakomana mumwe oga akabva kuna Baba, azere nenyasha nechokwadi."
    },
    {
      "verse": 385,
      "text": "Pari kutaurwa nezvani apa?"
    },
    {
      "verse": 386,
      "text": "Ndi ani akauya kune vake vakasa mugamuchira"
    },
    {
      "verse": 387,
      "text": "Hongu asi akanga asati ava munhu we nyama"
    },
    {
      "verse": 388,
      "text": "Endai pa 14 apo"
    },
    {
      "verse": 389,
      "text": "BVUNZO: Jesu akanga achiri shoko"
    },
    {
      "verse": 390,
      "text": "ANSWER: Izwi"
    },
    {
      "verse": 391,
      "text": "Ndo ramunoti tiri ve IZWI ra MWARI MU AFRICA"
    },
    {
      "verse": 392,
      "text": "Ndo ramunoti JOHANI, ndosaka verse iri riri mu bhuku rinonzi JOHANI"
    },
    {
      "verse": 393,
      "text": "Pa 14 hanzi kudiiko"
    },
    {
      "verse": 394,
      "text": "Mabva mapedza"
    },
    {
      "verse": 395,
      "text": "14. Shoko rakazova nyama, akagara pakati pedu, uye takaona kubwinya kwake, kubwinya sokwemwanakomana mumwe oga akabva kuna Baba, azere nenyasha nechokwadi."
    },
    {
      "verse": 396,
      "text": "SHONA akauya ku MASHONA"
    },
    {
      "verse": 397,
      "text": "MASHONA akasamu GAMUCHIRA"
    },
    {
      "verse": 398,
      "text": "SHONA akazova NYAMA , akagara pakati pedu tikaona kubwinya kwake"
    },
    {
      "verse": 399,
      "text": "NDOKUTI kune vaka gamuchira SHOKO,"
    },
    {
      "verse": 400,
      "text": "SHOKO rinozova munhu rogara pakati pavo"
    },
    {
      "verse": 401,
      "text": "MOSES raiva SHOKO rakava MUNHU"
    },
    {
      "verse": 402,
      "text": "Jesu raiva SHOKO rakava MUNHU"
    },
    {
      "verse": 403,
      "text": "Vakaramba SHOKO risati rava munhu , ndo vachangori ramba rava MUNHU"
    },
    {
      "verse": 404,
      "text": "Ndochienda paya pekuti"
    },
    {
      "verse": 405,
      "text": "Izwi raiporofita matambudziko raisava Mwari here"
    },
    {
      "verse": 406,
      "text": "RAIVA MWARI"
    },
    {
      "verse": 407,
      "text": "Paku tendeuka kunoita vanhu,"
    },
    {
      "verse": 408,
      "text": "JOHANI ano uya nema ZANO"
    },
    {
      "verse": 409,
      "text": "MAPIPI raiva zano"
    },
    {
      "verse": 410,
      "text": "Kwete musoro we nyaya"
    },
    {
      "verse": 411,
      "text": "KUPOROFITA nhamo nematambudziko raiva ZANO , kwete musoro we nyaya"
    },
    {
      "verse": 412,
      "text": "Zvose izvi zvaingo ITIRWA kuti VANHU vabvume ku TENDEUKA"
    },
    {
      "verse": 413,
      "text": "Asi kana CHAVAKA TENDEUTSIRWA chavapo, ZVINO MISWA"
    },
    {
      "verse": 414,
      "text": "Ipapo ndo pane DAMBUDZIKO"
    },
    {
      "verse": 415,
      "text": "Nekuti VAMWE VANOBVA vati HAZVISIRIZVO zveva BARI vedu"
    },
    {
      "verse": 416,
      "text": "Tiri kubviswa kuva BARI"
    },
    {
      "verse": 417,
      "text": "Ndo pandinoti ayewa MUCHABVA henyu kunhau dzeva BARI"
    },
    {
      "verse": 418,
      "text": "Nhau idzo dze kuporofita matambudziko"
    },
    {
      "verse": 419,
      "text": "Dzaingova dzeku ZIVISA vanhu kuti kune ari kuuya"
    },
    {
      "verse": 420,
      "text": "Ainzi ari kuuya ndi ani"
    },
    {
      "verse": 421,
      "text": "Ainzi ari ku uya ndi EMANUEL"
    },
    {
      "verse": 422,
      "text": "EMANUEL zvinorevei"
    },
    {
      "verse": 423,
      "text": "The name Emanuel (also spelled Immanuel) in English means:"
    },
    {
      "verse": 424,
      "text": "“God is with us.” ✅ Emanuel zvino fanira kunzi MWARI MU NESU"
    },
    {
      "verse": 425,
      "text": "Kwete ANESU"
    },
    {
      "verse": 426,
      "text": "Nekuti munesu ino nyatso taura zviviri zviripo"
    },
    {
      "verse": 427,
      "text": "Kana SHOKO risati rava munhu anotodya, rinenge riri munesu"
    },
    {
      "verse": 428,
      "text": "Asi rinenge richiti NDIRI MAMURI inside asi handisati NDABEREKWA outside se munhu chaiye"
    },
    {
      "verse": 429,
      "text": "Saka MUDYIWA aisava INI nenyama yake"
    },
    {
      "verse": 430,
      "text": "Aiva MWARI ari munesu"
    },
    {
      "verse": 431,
      "text": "Saka aigona kutsurwa na MWARI ari mune mumwewo"
    },
    {
      "verse": 432,
      "text": "IIIII SA KA"
    },
    {
      "verse": 433,
      "text": "MANUWERO aisava MANUWERO asi aiva MANUWERO"
    },
    {
      "verse": 434,
      "text": "Ahana kunyepa nezwi , akati"
    },
    {
      "verse": 435,
      "text": "NDIRI MAMURI ASI HANDISATI NDA BEREKWA 👩‍🍼 Semunhu"
    },
    {
      "verse": 436,
      "text": "Kwete kuti se IZWI"
    },
    {
      "verse": 437,
      "text": "Chinangwa chaive chekuti KANA munhu wese ava sa MANUWERE, iye MANUWERE aizo berekwa se MUNHU"
    },
    {
      "verse": 438,
      "text": "Chiri chiratidzo chekuti , ayewa zvatendwa MOSE MAVA na MWARI MUNEMI"
    },
    {
      "verse": 439,
      "text": "Asi vanhu vakaramba kuti MWARI mavari , inside them, MANUWERE aha berekwa se munhu"
    },
    {
      "verse": 440,
      "text": "Nekuti pa anozo berekwa se munhu , chinenge chiri chiratidzo chava kunze asi chichiratidza chimiro che zviri mukati ma Ani na Ani"
    },
    {
      "verse": 441,
      "text": "Nguva yose yatanga tiri yanga iri yekusika Mwari munesu"
    },
    {
      "verse": 442,
      "text": "Kana ava mandiri , ava mauri, ava matiri,"
    },
    {
      "verse": 443,
      "text": "Anobva azo berekwa se munhu, asi zvavabvu munesu"
    },
    {
      "verse": 444,
      "text": "Jesu ahauye kwatiri tisati tamusika matiri"
    },
    {
      "verse": 445,
      "text": "Zviri kunze, mucherechedzo bedzi we zviri mukati medu"
    },
    {
      "verse": 446,
      "text": "Zviri kubatika here"
    },
    {
      "verse": 447,
      "text": "Ndosaka nhasi ndavamba nekuti"
    },
    {
      "verse": 448,
      "text": "MWARI anofanira kuva MUNHU"
    },
    {
      "verse": 449,
      "text": "Ndo chinangwa"
    },
    {
      "verse": 450,
      "text": "Mwari anogara ku denga, saka kana MWARI amunhu , zvinoreva kuti MUNHU ava mudenga ari pasi"
    },
    {
      "verse": 451,
      "text": "Zvainzi pasi iri richava Jerusarema"
    },
    {
      "verse": 452,
      "text": "Ndakauya naro Jerusarema"
    },
    {
      "verse": 453,
      "text": "Johani Johani paradhiso"
    },
    {
      "verse": 454,
      "text": "Pasi penya se zvakaita denga"
    },
    {
      "verse": 455,
      "text": "Tichapaza jeriko tichivaka CANAAN"
    },
    {
      "verse": 456,
      "text": "Zvino kunakidza kwazvo inzwai"
    },
    {
      "verse": 457,
      "text": "Murume anogona kunge ari mudenga asi achitodya sadza ne Mudzimai wake ari panyika"
    },
    {
      "verse": 458,
      "text": "Denga hatipinde tose"
    },
    {
      "verse": 459,
      "text": "Asi tichifamba tose kune vanoona"
    },
    {
      "verse": 460,
      "text": "Hupinde ne mhuri"
    },
    {
      "verse": 461,
      "text": "Unopinda wega , mukadzi ari mugehena, asi muchidya ndiro imwe chete"
    },
    {
      "verse": 462,
      "text": "Saka zvekuti heee hatisati tava ne hwai, kunonoka"
    },
    {
      "verse": 463,
      "text": "Ita handisati ndava ne hwai"
    },
    {
      "verse": 464,
      "text": "Nekuti hauzive chimiro chemumwe wako na Mwari ma Ari"
    },
    {
      "verse": 465,
      "text": "Gurumwandira harina denga"
    },
    {
      "verse": 466,
      "text": "Ndambozorora"
    },
    {
      "verse": 467,
      "text": "Anenzeve ngaanzwe"
    },
    {
      "verse": 468,
      "text": "Ndichadzoka 🙏🏼🔥 Haisi mhosva kuti ndiri HWINDI, manje manje bus revanoenda KUDENGA rinozara"
    },
    {
      "verse": 469,
      "text": "Ndiri kuto Loader soooo"
    },
    {
      "verse": 470,
      "text": "Vasina hunhu , ndati buruka"
    },
    {
      "verse": 471,
      "text": "Usakanganwe kuti dzimwe nguva hwindi anokuitira hunhu hwe chi hwindi"
    },
    {
      "verse": 472,
      "text": "Ukazo nyara iwe nevawai nyepera"
    }
  ]
}