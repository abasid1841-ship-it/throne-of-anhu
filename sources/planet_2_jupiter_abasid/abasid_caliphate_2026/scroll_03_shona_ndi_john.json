    {
      "verse": 1,
      "text": "3.SHONA NDI JOHN 08/01/26"
    },
    {
      "verse": 2,
      "text": "Mangwanani vatendi"
    },
    {
      "verse": 3,
      "text": "Kune chaedza ne rima"
    },
    {
      "verse": 4,
      "text": "Ko kana chinhu chiri chaedza ne rima ,"
    },
    {
      "verse": 5,
      "text": "Tinochidedza kuti chiyi"
    },
    {
      "verse": 6,
      "text": "Kune kureba neku pfupika"
    },
    {
      "verse": 7,
      "text": "BVUNZO: Ko kana chinhu chirefu chiri chipfupi tinochi shevedza kuti chiyi"
    },
    {
      "verse": 8,
      "text": "ANSWER: hachina Zita"
    },
    {
      "verse": 9,
      "text": "Asi masara padiki mbichana kupasa"
    },
    {
      "verse": 10,
      "text": "Pamwe chinaro asi imi ndimi musingari zive 🙏🏻"
    },
    {
      "verse": 11,
      "text": "Nekuti haungati munhu ahana zita nekuti iwe haurizive"
    },
    {
      "verse": 12,
      "text": "Pindurai futi"
    },
    {
      "verse": 13,
      "text": "Chinonzi chiyi ???"
    },
    {
      "verse": 14,
      "text": "Chinhu chandareva apo"
    },
    {
      "verse": 15,
      "text": "Regai ndiku batsirei"
    },
    {
      "verse": 16,
      "text": "Ndivhunzei ini ndokupa mhinduro ye IDI"
    },
    {
      "verse": 17,
      "text": "Mwari harisi zita"
    },
    {
      "verse": 18,
      "text": "Mwari ane zita"
    },
    {
      "verse": 19,
      "text": "Asi ahasi zita"
    },
    {
      "verse": 20,
      "text": "Iwe une zita asi ahusi zita"
    },
    {
      "verse": 21,
      "text": "Tiri kuvhunza zita"
    },
    {
      "verse": 22,
      "text": "Munhu chausingazive dzidza kuti HAMENO"
    },
    {
      "verse": 23,
      "text": "Nekuti ukagona kuti Hameno unopa mukana kune anogona kunge achiziva , kuti aku dzidzise"
    },
    {
      "verse": 24,
      "text": "Dambudziko guru kuva mudzidzi kuno vambira pakugona kuti kuna mudzidzisi HAMENO"
    },
    {
      "verse": 25,
      "text": "Eheka, wataura chokwadi"
    },
    {
      "verse": 26,
      "text": "Ende iye ha anga kumanikidze ka kuti unofanira KUZIVA"
    },
    {
      "verse": 27,
      "text": "Iwe usinga zive"
    },
    {
      "verse": 28,
      "text": "Nhau yangu iri kuti ,"
    },
    {
      "verse": 29,
      "text": "KUZIVA kuno vamba musi wauno bvuma kuti HANDIZIVE"
    },
    {
      "verse": 30,
      "text": "Cup yakazara hai kwanise kupamhidzirwa"
    },
    {
      "verse": 31,
      "text": "Yakato zara ka nemvura, saka imwe mvura yamuri kuti dira kani , uri kuda kuti ndidire payi"
    },
    {
      "verse": 32,
      "text": "KUSAZIVA kuno kupa mukana we KUZIVA"
    },
    {
      "verse": 33,
      "text": "Haunga ZIVISA munhu zva ano ZIVA"
    },
    {
      "verse": 34,
      "text": "KUZIVISA kwacho kunenge kwava papi"
    },
    {
      "verse": 35,
      "text": "Zvaka fanana nekuti munhu agara ari kuto SEKA, iwe oti ndiri kuda kumu SEKESA"
    },
    {
      "verse": 36,
      "text": "Ndakubvunza futi,"
    },
    {
      "verse": 37,
      "text": "Chindipai answer iri correct , tione kuti mafunda here."
    },
    {
      "verse": 38,
      "text": "Chaedza ne Rima zvakabatana zvinonzi Chiyi???"
    },
    {
      "verse": 39,
      "text": "CHAEDZA + RIMA = ???"
    },
    {
      "verse": 40,
      "text": "Ukati handizive unenge wakutaura nezvimwe zvaka wanda, inga une zvimwewo zvauno ziva"
    },
    {
      "verse": 41,
      "text": "Hakuna munhu asinga zive"
    },
    {
      "verse": 42,
      "text": "Asi ukati hameno wapindura wakananga ne muvhunzo wavhunzwa"
    },
    {
      "verse": 43,
      "text": "Kuti ndo wausinga zive"
    },
    {
      "verse": 44,
      "text": "Ndo dambudziko, ku masowe"
    },
    {
      "verse": 45,
      "text": "Muno pihwa answer chaiyo asi munoisa mumashoko enyu"
    },
    {
      "verse": 46,
      "text": "Ini ndati unoti HAMENO"
    },
    {
      "verse": 47,
      "text": "AHHHH INI , HANDIZIVE"
    },
    {
      "verse": 48,
      "text": "Ku DZIDZA kunoda slow and careful"
    },
    {
      "verse": 49,
      "text": "BVUNZO: KUREBA + KUPFUPIKA = ????"
    },
    {
      "verse": 50,
      "text": "MHINDURO: HAMENO"
    },
    {
      "verse": 51,
      "text": "Ndo stage Gate 1"
    },
    {
      "verse": 52,
      "text": "Tese tati HAMENO"
    },
    {
      "verse": 53,
      "text": "Ini ndini ndato tangawo kuti HAMENO"
    },
    {
      "verse": 54,
      "text": "Chaedza chisati chavapo MWARI aivako"
    },
    {
      "verse": 55,
      "text": "RIMA risati ravako MWARI aivako"
    },
    {
      "verse": 56,
      "text": "Uyu MWARI uyu pa aivako ,hapana chimwe chinhu chaivako"
    },
    {
      "verse": 57,
      "text": "RIMA ne CHAEDZA zviva ma ARI"
    },
    {
      "verse": 58,
      "text": "Kufara neku SUWA zvaiva ma ARI"
    },
    {
      "verse": 59,
      "text": "Kureba neku pfupika zvaiva ma ARI"
    },
    {
      "verse": 60,
      "text": "BVUNZO: Zvino zvose izvo zvandati zvaiva Ma ARI,"
    },
    {
      "verse": 61,
      "text": "tati zvinonzi chiyi???"
    },
    {
      "verse": 62,
      "text": "ANSWER: Hameno"
    },
    {
      "verse": 63,
      "text": "Maku muka manje"
    },
    {
      "verse": 64,
      "text": "Tati HAMENO"
    },
    {
      "verse": 65,
      "text": "Kureba+kupfupika= Hameno"
    },
    {
      "verse": 66,
      "text": "Regai titangise, musa sare"
    },
    {
      "verse": 67,
      "text": "Chaedza chisati chavapo MWARI aivako"
    },
    {
      "verse": 68,
