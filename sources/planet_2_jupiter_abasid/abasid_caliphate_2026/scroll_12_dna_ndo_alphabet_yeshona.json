    {
      "verse": 211,
      "text": "Isu kwatiri yakati koshera"
    },
    {
      "verse": 212,
      "text": "Saka nyika dzose dzaiseka dzicha"
    },
    {
      "verse": 213,
      "text": "Tava kuti imi hamuende"
    },
    {
      "verse": 214,
      "text": "Imi munoenda"
    },
    {
      "verse": 215,
