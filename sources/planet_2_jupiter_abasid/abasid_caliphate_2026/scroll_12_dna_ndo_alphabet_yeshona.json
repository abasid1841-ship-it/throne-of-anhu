    {
      "verse": 313,
      "text": "vanotuka RA"
    },
    {
      "verse": 314,
      "text": "Vanotuka SHU"
    },
    {
      "verse": 315,
      "text": "Kuti isu tikanganwe ma shevedzero"
    },
    {
      "verse": 316,
      "text": "kana tanetswa ne vachena"
    },
    {
      "verse": 317,
      "text": "Chimboitai 🙏🏻 Regai ndiparidze hangu SHONA se zvizvi"
    },
    {
      "verse": 318,
      "text": "Munoda kudada ne CHIPOSITORI"
    },
    {
      "verse": 319,
      "text": "Muchikanganwa kuti pasina shona munono gara maka tarisana"
    },
    {
      "verse": 320,
      "text": "Tosangana later"
    },
    {
      "verse": 321,
      "text": "Maifanira kutenge muchinditi SIR,"
    },
    {
      "verse": 322,
      "text": "nekuti mota dze mweya dzandiri kukupai hadzisare mu NGU VA, ndedzenyu , mukafa munoenda nadzo CAR."
    },
    {
      "verse": 323,
      "text": "KUWANA HAKUFANANE,"
    },
    {
      "verse": 324,
      "text": "SIR vari kupa DZINO ONEKA ne PANYAMA"
    },
    {
      "verse": 325,
      "text": "INIWO idzodzo handina, saka ndokupai ka ma AQUA e MWEYA."
    },
    {
      "verse": 326,
      "text": "HAPANA ASIRI KU"
    },
    {
      "verse": 327,
      "text": "pakati pangu na SIR"
    },
    {
      "verse": 328,
      "text": "rudo chete ka ku PA"
    },
    {
      "verse": 329,
      "text": "Zvauno wana"
    },
    {
      "verse": 330,
      "text": "Ndosaka vasiri kukupai DZE MWEYA"
    },
    {
      "verse": 331,
      "text": "zvinoda BALANCE"
    },
    {
      "verse": 332,
      "text": "kwete kuti ku MUNHU SIR nekuti akupa mota yauno ona nemeso enyama"
    },
    {
      "verse": 333,
      "text": "Asi inoda kuonekwa ne meso emweya HA"
    },
    {
      "verse": 334,
      "text": "Saka HAMENO ikoko vanoda kunyengererwa"
    },
    {
      "verse": 335,
      "text": "Terera SHONA iri kuto paridzwa apa pasina hukwe"
    },
    {
      "verse": 336,
      "text": "Ndiri kudzoka"
    },
    {
      "verse": 337,
      "text": "Muchinjiko mitatu tose"
    },
    {
      "verse": 338,
      "text": "Mabva ma remember ano daro kumasowe"
    },
    {
      "verse": 339,
      "text": "SHONA i SHONA neku ghetto"
    },
    {
      "verse": 340,
      "text": "Ikarambwa ku MASOWE inongo paridza ku GHETTO"
    },
    {
      "verse": 341,
      "text": "Idi idi, nyangwe pa musika"
    }
