  "verse_count": 341,
  "verses": [
    {
      "verse": 1,
      "text": "12.DNA NDO ALPHABET YESHONA 11/01/25 Ini ndiri pano ndiri po kuti muzive kuti hakuna rufu"
    },
    {
      "verse": 2,
      "text": "Munhu wose anofa kana ari pambiri anodzoka zvizere mu generation yake yechi nomwe"
    },
    {
      "verse": 3,
      "text": "Asi nekuda kwekuti 7 iSABATA unodzoka pechi 6"
    },
    {
      "verse": 4,
      "text": "Hakuna rufu"
    },
    {
      "verse": 5,
      "text": "Ndiri kutaura zvangu ini panyama, kwete zve izwi"
    },
    {
      "verse": 6,
      "text": "Izwi harina zvekuti generation"
    },
    {
      "verse": 7,
      "text": "Ndiri kutaura munhu panyama"
    },
    {
      "verse": 8,
      "text": "Chaminuka - ini"
    },
    {
      "verse": 9,
      "text": "Abasid - ini"
    },
    {
      "verse": 10,
      "text": "Shona - Sabata"
    },
    {
      "verse": 11,
      "text": "Handisi kuti ndine mudzimu wa Chaminuka"
    },
    {
      "verse": 12,
      "text": "Ndiri kuti ndini"
    },
    {
      "verse": 13,
      "text": "Inonzi dna restored"
    },
    {
      "verse": 14,
      "text": "Dna ya chaminuka ndiyo iri mandiri ka"
    },
    {
      "verse": 15,
      "text": "Tarisai muone"
    },
    {
      "verse": 16,
      "text": "Munhu uka uraya munhu ,"
    },
    {
      "verse": 17,
      "text": "Ngozi yacho ino tambudza ani???"
    },
    {
      "verse": 18,
      "text": "Dzinza ka, nekuti ngozi haione FACE ino ona ropa"
    },
    {
      "verse": 19,
      "text": "Kwete ropa re red , nekuti iro rinogona ku flushwa ku hospital uchi pihwa remumwe"
    },
    {
      "verse": 20,
      "text": "Chinonzi ROPA ndo DNA"
    },
    {
      "verse": 21,
      "text": "Dai ngozi yaitevera ropa re red , handiti ppauno wedzerwa ropa kuchipatara waifanira kubva watora ne ngozi dze vaka donator ropa"
    },
    {
      "verse": 22,
      "text": "Sei pasina ati ambonzi ne muporofiti ngozi iri kuku netsa yabva muropa rawaka dhoneterwa"
    },
    {
      "verse": 23,
      "text": "Havazive vaporofiti ava"
    },
    {
      "verse": 24,
      "text": "Chinonzi ropa ra CHRISTU hapasi kutaurwa re red"
    },
    {
      "verse": 25,
      "text": "Re red rinongo shandiswa se muenzaniso"
    },
    {
      "verse": 26,
      "text": "Asi the DNA of CHRIST"
    },
    {
      "verse": 27,
      "text": "Iwe wakabva ku vabereki vako"
    },
    {
      "verse": 28,
      "text": "Vabereki vako vakabva ku vabereki vavo"
    },
    {
      "verse": 29,
      "text": "Ivavo vakabvavo kuvavo"
    },
    {
      "verse": 30,
      "text": "Kuzono svika pa munhu wekutanga"
    },
    {
      "verse": 31,
      "text": "Ko munhu wekutanga aivawo ne dna yani"
    },
    {
      "verse": 32,
      "text": "Munhu weku tanga aiva ne DNA ya MWARI"
    },
    {
      "verse": 33,
      "text": "Iyoyo DNA ya MWARI ndiyo inonzi CHRISTU"
    },
    {
      "verse": 34,
      "text": "Ndo ropa rataka mirira"
    },
    {
      "verse": 35,
      "text": "DNA iyi yaisava ne ngozi"
    },
    {
      "verse": 36,
      "text": "Saka munhu wekutanga akanga ari pure"
    },
    {
      "verse": 37,
      "text": "Hakuna chakaipa chaimu rwisa"
    },
    {
      "verse": 38,
      "text": "DNA yake yaiva 100%"
    },
    {
      "verse": 39,
      "text": "Saka akararamawo nguva yake, asi muku rarama uku akatadzawo zvishoma semunhu"
    },
    {
      "verse": 40,
      "text": "Mhosva yekutanga yaiva yekuti akazvi kudza"
    },
    {
      "verse": 41,
      "text": "Ndo rungano rwe muchero pa Eden"
    },
    {
      "verse": 42,
      "text": "Akaita zva akanga anzi usazoita"
    },
    {
      "verse": 43,
      "text": "Handicha taura chivi chacho"
    },
    {
      "verse": 44,
      "text": "Kureva kuti mwana wa aka bereka anga asina 100% pure DNA"
    },
    {
      "verse": 45,
      "text": "Nekuti baba tomboti vakanga vava 90% kuyera muropa"
    },
    {
      "verse": 46,
      "text": "Iyewo akabva aparawo dzake"
    },
    {
      "verse": 47,
      "text": "Zvekuti wa akabereka akanga avawo 80% kuyera muropa"
    },
    {
      "verse": 48,
      "text": "Munhu wekutanga aityiwa ne shumba"
    },
    {
      "verse": 49,
      "text": "Aikumbira sadza pamuhacha"
    },
    {
      "verse": 50,
      "text": "Aitaura ne mhuka"
    },
    {
      "verse": 51,
      "text": "Asi pakazoita chizukuru chechi shanu anga akutotya ndiye shumba"
    },
    {
      "verse": 52,
      "text": "Ende dzakanga dzakumu dherera"
    },
    {
      "verse": 53,
      "text": "Se zvatiri nhasi tichi rumwa ne nyoka"
    },
    {
      "verse": 54,
      "text": "Inhau yekuti DNA ya dhakwa"
    },
    {
      "verse": 55,
      "text": "Mhosva ino tevera dna,"
    },
    {
      "verse": 56,
      "text": "Nekuti DNA yako ndo iwe"
    },
    {
      "verse": 57,
      "text": "Saka sekuru vako ndiwe"
    },
    {
      "verse": 58,
      "text": "Kana vaja uraya, ndiwe waka uraya"
    },
    {
      "verse": 59,
      "text": "Saka ichinzi haibve ne muteuro, inobva neku ripwa"
    },
    {
      "verse": 60,
      "text": "Muteuro unongo nyaradza"
    },
    {
      "verse": 61,
      "text": "Asi kwete kubvisa"
    },
    {
      "verse": 62,
      "text": "Saka kana ngozi ichiti sekuru vangu ndini, zvoreva ka kuti sekuru vangu ndini"
    },
    {
      "verse": 63,
      "text": "Ndikati CHAMINUKA ndini, ndinenge ndanyepa papi"
    },
    {
      "verse": 64,
      "text": "Sei ngozi yake ichinetsa ini, kana ndisirini"
    },
    {
      "verse": 65,
      "text": "Hazvi perere pa ngozi ne zvakaipa chete"
    },
    {
      "verse": 66,
      "text": "Kana aiva nezwi ra Mwari, neniwo ndinaro"
    },
    {
      "verse": 67,
      "text": "Imi makati handina, ndinongoti ayewa ndo MAONERO enyu"
    },
    {
      "verse": 68,
      "text": "Ndava ku tsanangura dna ya MWARI yakapihwa munhu wekutanga"
    },
    {
      "verse": 69,
      "text": "Achagashira dzidziso, ndo kugashira ROPA ra CHRISTU"
    },
    {
      "verse": 70,
      "text": "Ndombopa mukana vari kuda kubudavne vari kuda kumbo taura 🙏🏻🙏🏻🙏🏻☀️"
    },
    {
      "verse": 71,
      "text": "Right , ngatifambe"
    },
    {
      "verse": 72,
      "text": "Chi chinonzi kupa munhu ma INSTRUCTIONS???"
    },
    {
      "verse": 73,
      "text": "Kuudzwa zvekuita"
    },
    {
      "verse": 74,
      "text": "Zvino kana kuri kutaurira munhu zvekuita handiti kureva kuti pane IZWI?"
    },
    {
      "verse": 75,
      "text": "Zvino dna , ivara rechi rungu rinongo reva kuti instructions"
    },
    {
      "verse": 76,
      "text": "Kureva kuti ,"
    },
    {
      "verse": 77,
      "text": "Dna inobva kuvabereki ichienda ku mwana ma instructions"
    },
    {
      "verse": 78,
      "text": "Dna ma instructions"
    },
    {
      "verse": 79,
      "text": "Saka dna IZWI"
    },
    {
      "verse": 80,
      "text": "Pakusikwa kwe mwana mudumbu, kunobva dna kuna Baba ne dna kuna Amai"
    },
    {
      "verse": 81,
      "text": "Saka kunobva izwi kuna baba kwobva izwi kuna Mai"
    },
    {
      "verse": 82,
      "text": "In the beginning was the word"
    },
    {
      "verse": 83,
      "text": "Pakatanga kwako iwe kwaiva ne izwi"
    },
    {
      "verse": 84,
      "text": "Izwi rakabva kuna baba raiti, mhuno yake ngaive yakadai, nekuti ini baba vake ndakadai,"
    },
    {
      "verse": 85,
      "text": "Anofanira kugona chikoro nekuti ini baba vake ndogona chikoro"
    },
    {
      "verse": 86,
      "text": "Nga ave nengozi nekuti ini baba wake ndakauraya munhu"
    },
    {
      "verse": 87,
      "text": "Nga ave ne chirwere chakati nekuti ini baba vake ndine chirwere ichocho"
    },
    {
      "verse": 88,
      "text": "Ndo zvirwere zviya zvinonzi inherited"
    },
    {
      "verse": 89,
      "text": "Nga ave mambo nekuti ini baba vake ndiri mambo"
    },
    {
      "verse": 90,
      "text": "Nga ave ne nhaka ya Mwari iyi nekuti ini baba vake ndine nhaka ya Mwari iyi"
    },
    {
      "verse": 91,
      "text": "Ndopanobva nhau ya Abraham achisira isaka kusvika kuna Jakopo kusvika kuna Jesu"
    },
    {
      "verse": 92,
      "text": "Nga ave mutsvuku nekuti ini baba vake ndiri mutsvuku"
    },
    {
      "verse": 93,
      "text": "Ndo zvinopa Mwana kufanana ne vabereki"
    },
    {
      "verse": 94,
      "text": "Zvimwe chete nekuna Amai, kunobva futi izwi kana kuti dna kana kuti ma instructions kuna Amai"
    },
    {
      "verse": 95,
      "text": "Achiti Mwana uyu nga ave akadaiso"
    },
    {
      "verse": 96,
      "text": "Dna yabva kuna baba , inosangana ne dna yabva kuna AMAI zvo govana mu mwana"
    },
    {
      "verse": 97,
      "text": "Dna ya Amai inogona kuti ayewa ku dna yababa, mwana nga asave mutsvuku semi , nga ave mutema seni"
    },
    {
      "verse": 98,
      "text": "Dna ya Baba yoti ok tadi kuti achingoita mushava pakati ne pakati"
    },
    {
      "verse": 99,
      "text": "Dna ya Amai yoti ok ngaave mushava"
    },
    {
      "verse": 100,
      "text": "Ndo zvinonzi munhu wose akasikwa nezwi"
    },
    {
      "verse": 101,
      "text": "Ndosaka mwana achiberekwa anotoziva kuchema"
    },
    {
      "verse": 102,
      "text": "Ku digester chikafu"
    },
    {
      "verse": 103,
      "text": "Pasina amu dzidzisa"
    },
    {
      "verse": 104,
      "text": "Nekuti instructer ari ma ari"
    },
    {
      "verse": 105,
      "text": "Ndo izwi riri muna ani na ani"
    },
    {
      "verse": 106,
      "text": "Mwana mucheche akavaiwa ano kwenya"
    },
    {
      "verse": 107,
      "text": "Asi hapana akamuudza"
    },
    {
      "verse": 108,
      "text": "Kureva kuti mwana tichiona asi ka mdara"
    },
    {
      "verse": 109,
      "text": "Kakagara kariko"
    },
    {
      "verse": 110,
      "text": "Hakuna panotaurwa ne izwi pasina mavara ano sika izwi"
    },
    {
      "verse": 111,
      "text": "Kuchirungu vano shandisa"
    },
    {
      "verse": 112,
      "text": "Ndichazvi tsanangura"
    },
    {
      "verse": 113,
      "text": "Tongoti C zvinoreva NGA AVE"
    },
    {
      "verse": 114,
      "text": "G Zvichireva kuti mutsvuku"
    },
    {
      "verse": 115,
      "text": "Dna ino svika ku mwana ari mavara maviri akatedzana"
    },
    {
      "verse": 116,
      "text": "achireva kuti NGA AVE"
    },
    {
      "verse": 117,
      "text": "achireva kuti mutsvuku"
    },
    {
      "verse": 118,
      "text": "Sandizvo exactly"
    },
    {
      "verse": 119,
      "text": "Ndiri kuda kuti mufunde mbichana mbichana"
    },
    {
      "verse": 120,
      "text": "Anobva kuna BABA"
    },
    {
      "verse": 121,
      "text": "Anobva kuna"
    },
    {
      "verse": 122,
      "text": "iwe mwana obva wava ne"
    },
    {
      "verse": 123,
      "text": "Saka munhu wose ane 46 mavara anosika zva ari"
    },
    {
      "verse": 124,
      "text": "Ndo dna ye munhu"
    },
    {
      "verse": 125,
      "text": "Iwe uka roorarawo unotumira 23 kumwana wako, asi hazvireve kuti uno sara ne 23,"
    },
    {
      "verse": 126,
      "text": "Unongo ramba uine 23"
    },
    {
      "verse": 127,
      "text": "Pane copying inoitwa kwotumirwa copy"
    },
    {
      "verse": 128,
      "text": "Ndati handisi kutaura zvakadzama, ndiri kugadzira kuti muwane idea"
    },
    {
      "verse": 129,
      "text": "23 mavara akabva kuna baba vako anonzi ma CHROMOSOMES"
    },
    {
      "verse": 130,
      "text": "zvimwe chete ne akabva kwa AMAI"
    },
    {
      "verse": 131,
      "text": "23 CHROMOSOMES futi"
    },
    {
      "verse": 132,
      "text": "But manje pa 23 mavara aya , rechi 23 harisi vara, ndiye MWARI MUMUNHU pachake"
    },
    {
      "verse": 133,
      "text": "Ndiro rino sarudza kuti mwana ave mukomana kana kuti musikana"
    },
    {
      "verse": 134,
      "text": "Asi mavara anosika zvimwe zvose i 22"
    },
    {
      "verse": 135,
      "text": "Chinzwai apa"
    },
    {
      "verse": 136,
      "text": "Dna yekutanga zvayakabva kuna MWARI, zvinoreva kuti KUNA mwari kwakabva ma instructions"
    },
    {
      "verse": 137,
      "text": "Ma instructions aya toti ndo akasika munhu weku tanga"
    },
    {
      "verse": 138,
      "text": "Ngatimuti ADAM"
    },
    {
      "verse": 139,
      "text": "Dna iyi RAIVA"
    },
    {
      "verse": 140,
      "text": "IZWI ra MWARI rakano umba ADAM"
    },
    {
      "verse": 141,
      "text": "Asi ka takuziva kuti hakuna IZWI pasina mavara"
    },
    {
      "verse": 142,
      "text": "Saka ADAM akasikwa ne ma vara"
    },
    {
      "verse": 143,
      "text": "Ai wumba kutaura kwa MWARI"
    },
    {
      "verse": 144,
      "text": "Mavara aya aiva 22"
    },
    {
      "verse": 145,
      "text": "Ndo mavara e ALPHABET ye SHONA"
    },
    {
      "verse": 146,
      "text": "Saka munhu akasikwa ne SHONA"
    },
    {
      "verse": 147,
      "text": "Munhu AKASIKWA ne izwi ra MWARI rinonzi JOHANI"
    },
    {
      "verse": 148,
      "text": "Nekuti SHONA ndi JOHANI"
    },
    {
      "verse": 149,
      "text": "Ndosaka JOHANI ari mukuru"
    },
    {
      "verse": 150,
      "text": "Nekuti hakuna chakasikwa chisina kusikwa kuburikidza naye"
    },
    {
      "verse": 151,
      "text": "Nekuti NDIYE"
    },
    {
      "verse": 152,
      "text": "LANGUAGE ya MWARI"
    },
    {
      "verse": 153,
      "text": "IZWI RA MWARI MU AFRICA"
    },
    {
      "verse": 154,
      "text": "Munhu wekutanga aiva ne 45 chromosomes,"
    },
    {
      "verse": 155,
      "text": "Isu tine 46, ndichataura kuti sei"
    },
    {
      "verse": 156,
      "text": "22 CHROMOSOMES dzakabva kuna MWARI ,ndo 22 letters of SHONA ALPHABET"
    },
    {
      "verse": 157,
      "text": "Ndiwo mavara anoumba mutauro we shona wokutanga"
    },
    {
      "verse": 158,
      "text": "Maona ndatoti woku"
    },
    {
      "verse": 159,
      "text": "vanongobva pana"
    },
    {
      "verse": 160,
      "text": "vongobva pana"
    },
    {
      "verse": 161,
      "text": "Asi kuna amwe atinoti ma minor , aya ma major, ndo 22"
    },
    {
      "verse": 162,
      "text": "Ose ma major nema minor anozoita 78"
    },
    {
      "verse": 163,
      "text": "Ma minor ndo ana"
    },
    {
      "verse": 164,
      "text": "Panobva ti chiyi"
    },
    {
      "verse": 165,
      "text": "DZABVA TSAMWA"
    },
    {
      "verse": 166,
      "text": "Ndo zvandaudzwa izvezvi"
    },
    {
      "verse": 167,
      "text": "Kureva kuti ndanzi idzo dzakuda kubva utsamwe kana dzabva"
    },
    {
      "verse": 168,
      "text": "Saka regai ndi TSAMWE"
    },
    {
      "verse": 169,
      "text": "Kuita left ndichikupa hupenyu"
    },
    {
      "verse": 170,
      "text": "Hazvi tsamwise here"
    },
    {
      "verse": 171,
      "text": "Manje ndadzi tangira"
    },
    {
      "verse": 172,
      "text": "Dzabva dza nya ra"
    },
    {
      "verse": 173,
      "text": "Anyway, nda tsa mwa , zvapera 🙏🏻 Totsanangura vara rega rega"
    },
    {
      "verse": 174,
      "text": "Anoreva MWARI mumwe chete"
    },
    {
      "verse": 175,
      "text": "Imba kana muviri we munhu , nekuti ndiyo IMBA inogara A"
    },
    {
      "verse": 176,
      "text": "ZVINOREVA MWANA, kana kuti chibereko chino berekwa ne kuyanana kwe zviviri zvokutanga"
    },
    {
      "verse": 177,
      "text": "MWARI pa akati"
    },
    {
      "verse": 178,
      "text": "kwakabva kwava ne ZUVA"
    },
    {
      "verse": 179,
      "text": "ZUVA IRORO ndiye RA"
    },
    {
      "verse": 180,
      "text": "RA ☀️ Zvinoreva zuva, ndiro rakabva rava mufananidzo wa A"
    },
    {
      "verse": 181,
      "text": "MA 🌓 Zvinoreva MWEDZI, ndiwo wakabva wava mufananidzo wa BA"
    },
    {
      "verse": 182,
      "text": "Saka husiku ndi MWARI"
    },
    {
      "verse": 183,
      "text": "ndokuti arima kana kuti ava rima"
    },
    {
      "verse": 184,
      "text": "RA ☀️ anotonga masikati"
    },
    {
      "verse": 185,
      "text": "MA 🌓 anotonga husiku"
    },
    {
      "verse": 186,
      "text": "Saka tava apa"
    },
    {
      "verse": 187,
      "text": "kwedu panyika kuno tangira paka sangana"
    },
    {
      "verse": 188,
      "text": "MA 🌓 Ndosaka kuchinzi ku"
    },
    {
      "verse": 189,
      "text": "Ndozvinobva zvatipa vara rino tevera"
    },
    {
      "verse": 190,
      "text": "DA ♥️ zvinoreva RUDO"
    },
    {
      "verse": 191,
      "text": "kana kuti ku"
    },
    {
      "verse": 192,
      "text": "Munhu kana chinhu"
    },
    {
      "verse": 193,
      "text": "Kana paita RUDO panova ne CONNECTION"
    },
    {
      "verse": 194,
      "text": "ndo zvinotipa vara rinotevera ,"
    },
    {
      "verse": 195,
      "text": "Kubatanidzwa kwe zvinhu zviviri kana vanhu vayiri"
    },
    {
      "verse": 196,
      "text": "Mavara ese aya HUMWARI Humwe chete"
    },
    {
      "verse": 197,
      "text": "Mazita ake futi ose"
    },
    {
      "verse": 198,
      "text": "DA ♥️ here???"
    },
    {
      "verse": 199,
      "text": "INI ☀️ Ndopanotipa vara rino tevera, rinova"
    },
    {
      "verse": 200,
      "text": "rinoreva kufanana kwe zvinhu kana vanhu"
    },
    {
      "verse": 201,
      "text": "INI ☀️ Muchatova ne ZIVO rinoto pfuura RA ☀️ INI"
