    },
    {
      "verse": 216,
      "text": "Handireve nhema ini"
    },
    {
      "verse": 217,
      "text": "Vacha nyara"
    },
    {
      "verse": 218,
      "text": "RA ☀️ Zvavo."
    },
    {
      "verse": 219,
      "text": "Kunyarara chaiko kuita silent,"
    },
    {
      "verse": 220,
      "text": "ndo patinobva tawana vara redu rino tevera , rinova"
    },
    {
      "verse": 221,
      "text": "Kusvika vazongoti"
    },
    {
      "verse": 222,
      "text": "Isu tobva TA vati , hongu TA"
    },
    {
      "verse": 223,
      "text": "Ndo patawana vara redu rechi gumi,"
    },
    {
      "verse": 224,
      "text": "Zvinoreva kuti"
    },
    {
      "verse": 225,
      "text": "WE ARE muchirungu"
    },
    {
      "verse": 226,
      "text": "Kunama is to join"
    },
    {
      "verse": 227,
      "text": "Ku BA TA nidza"
    },
    {
      "verse": 228,
      "text": "Pese apa hatai gona kuti TA"
    },
    {
      "verse": 229,
      "text": "Nekuti mumwe ne mumwe anga aine maonero ake"
    },
    {
      "verse": 230,
      "text": "Saka Tanga tisiri pamwe chete"
    },
    {
      "verse": 231,
      "text": "Ukaita chinhu chako wega , hauti TA dai"
    },
    {
      "verse": 232,
      "text": "Zvinoreva kuti"
    },
    {
      "verse": 233,
      "text": "WAKA TSEMURA TA"
    },
    {
      "verse": 234,
      "text": "Saka vazhinji havasi kunama"
    },
    {
      "verse": 235,
      "text": "asi vari kunama"
    },
    {
      "verse": 236,
      "text": "Kuda kuita zvake zve musoro waje asinga vhunzewo vamwe"
    },
    {
      "verse": 237,
      "text": "Chimbo fundai iwawa"
    },
    {
      "verse": 238,
      "text": "Right handei pana NGU"
    },
    {
      "verse": 239,
      "text": "Munhu wose ane chinhu chake anoti ndecha"
    },
    {
      "verse": 240,
      "text": "Iwe uka vhunzwa unoti kuti mota iyi ndeyani"
    },
    {
      "verse": 241,
      "text": "Unoti ndeya"
    },
    {
      "verse": 242,
      "text": "Ini ndikavhunzwawo ndinoti"
    },
    {
      "verse": 243,
      "text": "Ari kunzi NGU uyu ndiani"
    },
    {
      "verse": 244,
      "text": "Anova muridzi we zvinhu zvine vanhu vose"
    },
    {
      "verse": 245,
      "text": "Ndo pane nyaya ya"
    },
    {
      "verse": 246,
      "text": "NGU izita ra MWARI ari TIME"
    },
    {
      "verse": 247,
      "text": "Zvinhu zvose ndezve NGUVA"
    },
    {
      "verse": 248,
      "text": "Munhu ane mota 100 pa anofa aha ende nadzo"
    },
    {
      "verse": 249,
      "text": "Dzino sara ne muridzi wadzo anova NGUVA"
    },
    {
      "verse": 250,
      "text": "Nguva ndiyo inozo sarudza kuti ko ka bus topa ani"
    },
    {
      "verse": 251,
      "text": "Mukadzi wa asiya topa ani"
    },
    {
      "verse": 252,
      "text": "Kureva kuti hatina chedu panyika"
    },
    {
      "verse": 253,
      "text": "Mwari anoti ndezva NGU"
    },
    {
      "verse": 254,
      "text": "Nyangwe isu patinoti ndezva"
    },
    {
      "verse": 255,
      "text": "Tinenge tisinga reve isu"
    },
    {
      "verse": 256,
      "text": "Takanga tava pana"
    },
    {
      "verse": 257,
      "text": "ku alphabet"
    },
    {
      "verse": 258,
      "text": "Tati TA zvinoreva kuti WE ARE muchirungu"
    },
    {
      "verse": 259,
      "text": "Vara rino tevera TA ndi VA"
    },
    {
      "verse": 260,
      "text": "VA rino reva THEY ARE kana kuti paku kudza munhu mukuru"
    },
    {
      "verse": 261,
      "text": "Vara rino tevera VA ndi NGU"
    },
    {
      "verse": 262,
      "text": "NGU zvinoreva MWARI se TIME"
    },
    {
      "verse": 263,
      "text": "Asi patinozoti"
    },
    {
      "verse": 264,
      "text": "tiri kutaura"
    },
    {
      "verse": 265,
      "text": "zva anenge a VA"
    },
    {
      "verse": 266,
      "text": "dzekudya sadza"
    },
    {
      "verse": 267,
      "text": "dze kunamata"
    },
    {
      "verse": 268,
      "text": "NGU ahagare ari chinhu chimwe chete"
    },
    {
      "verse": 269,
      "text": "Zva ari iye zvino zvato siyana ne zva achava after 2 seconds"
    },
    {
      "verse": 270,
      "text": "Saka kuchinja kwe chimiro cha NGU , ndo kufamba kwe time"
    },
    {
      "verse": 271,
      "text": "Ukangoti hongu watoti IDI"
    },
    {
      "verse": 272,
      "text": "Zvino NGU ndiye IDI"
    },
    {
      "verse": 273,
      "text": "Saka achishandiswa paku bvuma"
    },
    {
      "verse": 274,
      "text": "Handisi kunyepa"
    },
    {
      "verse": 275,
      "text": "Handisi kufananidza"
    },
    {
      "verse": 276,
      "text": "Ndo panobva kuti"
    },
    {
      "verse": 277,
      "text": "Kureva Mwari"
    },
    {
      "verse": 278,
      "text": "Vara rino tevera ndi NDA"
    },
    {
      "verse": 279,
      "text": "NDA zvino reva kuti I AM"
    },
    {
      "verse": 280,
      "text": "Vara rinotevera NDA ndi PA"
    },
    {
      "verse": 281,
      "text": "PA zvinoreva the spirit of GIVING"
    },
    {
      "verse": 282,
      "text": "Wava PA here"
    },
    {
      "verse": 283,
      "text": "Unofanira ku"
    },
    {
      "verse": 284,
      "text": "Vara rino tevera PA ndi HA"
    },
    {
      "verse": 285,
      "text": "HA zvinoreva kuramba"
    },
    {
      "verse": 286,
      "text": "Vara rino tevera HA ndi GA"
    },
    {
      "verse": 287,
      "text": "GA kusima , kudyara"
    },
    {
      "verse": 288,
      "text": "Chingoti GA GA"
    },
    {
      "verse": 289,
      "text": "Ndozvandiri kuita wani"
    },
    {
      "verse": 290,
      "text": "Vara rino tevera GA ndi SHU"
    },
    {
      "verse": 291,
      "text": "SHU zvino taura MHEPO"
    },
    {
      "verse": 292,
      "text": "Iyi ngirozi ine simba guru"
    },
    {
      "verse": 293,
      "text": "Ndo MHEPO ye mudzimu wa MWARI"
    },
    {
      "verse": 294,
      "text": "Saka ndo MWEYA MUTSVENE"
    },
    {
      "verse": 295,
      "text": "Kumasowe ngirozi iyi ndo yatinoti GINATSIO"
    },
    {
      "verse": 296,
      "text": "Kana kuti IGNATIUS kuvarungu"
    },
    {
      "verse": 297,
      "text": "Uka BATANIDZA"
    },
    {
      "verse": 298,
      "text": "RA ☀️ Ndopano gadzirwa ma PIPI"
    },
    {
      "verse": 299,
      "text": "Nekuti MHEPO ino takura chinanara asi panoda Zuva kuti vaitirwa bipi varione"
    },
    {
      "verse": 300,
      "text": "Hatisati tatanga kuno"
    },
    {
      "verse": 301,
      "text": "Chasara kuva sanganisa"
    },
    {
      "verse": 302,
      "text": "Mozo ona SHURA GURA mupasi"
    },
    {
      "verse": 303,
      "text": "Vano sanganiswa ne MUTEURO"
    },
    {
      "verse": 304,
      "text": "Mhepo ndi batsire kutaura matare"
    },
    {
      "verse": 305,
      "text": "Unenge woshevedza SHU"
    },
    {
      "verse": 306,
      "text": "Zuva ndivhenekere"
    },
    {
      "verse": 307,
      "text": "Wo shevedze"
    },
    {
      "verse": 308,
      "text": "Zvino handisati ndava kukwanisa kukupai mabikirwo e mapipi"
    },
    {
      "verse": 309,
      "text": "Nekuti Munozo shandisa pasiripo"
    },
    {
      "verse": 310,
      "text": "Ini ndini BIPI rema PIPI rino PIPAIDZA ma PIPI"
    },
    {
      "verse": 311,
      "text": "Ndokutaura kwa SHU na RA"
    },
    {
      "verse": 312,
      "text": "Ndisu mhani"
