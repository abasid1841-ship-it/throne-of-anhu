    },
    {
      "verse": 205,
      "text": "RA ☀️ NDINI"
    },
    {
      "verse": 206,
      "text": "Kana kuti hona SARAH"
    },
    {
      "verse": 207,
      "text": "Handiti vaiseka ZIMBABWE"
    },
    {
      "verse": 208,
      "text": "Vachiti haina MWANA"
    },
    {
      "verse": 209,
      "text": "Mirai muone"
    },
    {
