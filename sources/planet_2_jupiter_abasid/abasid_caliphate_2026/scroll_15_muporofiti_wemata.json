{
  "id": "abasid_caliphate_15_muporofiti_wemata",
  "title": "MUPOROFITI WEMATA",
  "english_title": "Prophet of the Frog",
  "author": "ABASID 1841",
  "compiler": "Lord Blessed Murove",
  "tradition": "Abasid",
  "language": "Shona/English",
  "date": "13/01/26",
  "collection": "THE ABASID CALIPHATE",
  "description": "Teaching from THE ABASID CALIPHATE collection: MUPOROFITI WEMATA (Prophet of the Frog)",
  "keywords": [
    "muporofiti",
    "prophet",
    "mata",
    "frog",
    "prophecy"
  ],
  "verse_count": 232,
  "verses": [
    {
      "verse": 1,
      "text": "15.MUPOROFITI WEMATA 🐸 13/01/26 Mangwanani Hama dzadiwa,"
    },
    {
      "verse": 2,
      "text": "Zuva ndi RA ☀️, Zuva ndi MUFA NDICHI MUKA."
    },
    {
      "verse": 3,
      "text": "ZUVA rinofa Zuva rega rega mawuro."
    },
    {
      "verse": 4,
      "text": "ZUVA rino muka zuva rega rega mangwanani."
    },
    {
      "verse": 5,
      "text": "KUMUKA kwe zuva mangwanani , tinoti kubarwa kwaro mangwanani."
    },
    {
      "verse": 6,
      "text": "RA is BORN every morning"
    },
    {
      "verse": 7,
      "text": "RA is the SUN"
    },
    {
      "verse": 8,
      "text": "Izuva guru EMANUWERE"
    },
    {
      "verse": 9,
      "text": "RA is the SON"
    },
    {
      "verse": 10,
      "text": "Kana kuti RAISON"
    },
    {
      "verse": 11,
      "text": "Zvino RAISON ndiyo TSVIMBO tangu yakadzika pa MARIMBA"
    },
    {
      "verse": 12,
      "text": "Moses zva akakona va Porofiti ve"
    },
    {
      "verse": 13,
      "text": "MAFARO akava kona ne kuti taura"
    },
    {
      "verse": 14,
      "text": "Kutaura kunonzi NDIMI"
    },
    {
      "verse": 15,
      "text": "Kana kuti RURIMI"
    },
    {
      "verse": 16,
      "text": "zvino RURIMI"
    },
    {
      "verse": 17,
      "text": "Zvichinzi TSVIMBO ya EMOSES yaisanduka kuita NYOKA"
    },
    {
      "verse": 18,
      "text": "Zvinongo reva kuti yaiva NDIMI yamedza dzimwe NDIMI"
    },
    {
      "verse": 19,
      "text": "Kwaiva kutaura"
    },
    {
      "verse": 20,
      "text": "TSVIMBO ya EMOSES"
    },
    {
      "verse": 21,
      "text": "Iiiiii sa ka"
    },
    {
      "verse": 22,
      "text": "Chakashamisa ndiko kutaura"
    },
    {
      "verse": 23,
      "text": "MOSES wakasimudza NYOKA murenje"
    },
    {
      "verse": 24,
      "text": "Ukaitarisa unopona"
    },
    {
      "verse": 25,
      "text": "Moses waka patsanura gungwa neku TAURA"
    },
    {
      "verse": 26,
      "text": "Nemiwo muka vimba ne kutaura muchaputsa makomo mberi kwenyu"
    },
    {
      "verse": 27,
      "text": "Jesu ano fananidzwa ne nyoka, hazvireve SATAN asi zvinoreva kuti JESU IZWI"
    },
    {
      "verse": 28,
      "text": "Jesu kutaura"
    },
    {
      "verse": 29,
      "text": "Ndizvo kare tiri ku EGYPT taiti hautonge usina kutsiga JESU."
    },
    {
      "verse": 30,
      "text": "Hautonge usina kudziga ZUVA"
    },
    {
      "verse": 31,
      "text": "INYOKA ndo CHIREMBA changu chisina ani na ani"
    },
    {
      "verse": 32,
      "text": "Munhu akati ndangonzwa ndanzi"
    },
    {
      "verse": 33,
      "text": "anenge achiti ndarumwa"
    },
    {
      "verse": 34,
      "text": "Vari rekuti"
    },
    {
      "verse": 35,
      "text": "Rinobva pakuti"
    },
    {
      "verse": 36,
      "text": "NGA ndiro vara reku pedzisira mu ALPHABET yedu ye SHONA"
    },
    {
      "verse": 37,
      "text": "Kureva kuti NGA izita ra MWARI zvakare kufanana na RA"
    },
    {
      "verse": 38,
      "text": "Zvino NGA zvariri zita reku pedzisira ra MWARI,"
    },
    {
      "verse": 39,
      "text": "isu ngatidei kuzvika kumagumo gumo mukufunda Mwari Tadaro tinenge tade ♥️ NGA"
    },
    {
      "verse": 40,
      "text": "Kude ♥️ NGA"
    },
    {
      "verse": 41,
      "text": "Kwatinoda kusvika"
    },
    {
      "verse": 42,
      "text": "Saka iye akati wose ava kude NGA,"
    },
    {
      "verse": 43,
      "text": "Zvino anenge amuda"
    },
    {
      "verse": 44,
      "text": "ahadyiwe nema pere"
    },
    {
      "verse": 45,
      "text": "Nekuti ava kurarama muna JEHOVAH"
    },
    {
      "verse": 46,
      "text": "Iiiii sa ka"
    },
    {
      "verse": 47,
      "text": "Jehovah wakatipa MWENJE wake se TSVIMBO se mutauro , kuti ugoti vhenekera tigo kwanisa kuona Nzira yekude"
    },
    {
      "verse": 48,
      "text": "Iyi Tsvimbo iyi ndiyo"
    },
    {
      "verse": 49,
      "text": "Yevano namata"
    },
    {
      "verse": 50,
      "text": "NGA = MWARI"
    },
    {
      "verse": 51,
      "text": "RA = SUN/SON"
    },
    {
      "verse": 52,
      "text": "VA = zva ava"
    },
    {
      "verse": 53,
      "text": "Saka Mwari ne zuva zvazvinenge zva VA ndo mweya mutsvene"
    },
    {
      "verse": 54,
      "text": "Saka Mweya unogona kuva icho kana icho, saka ngirozi dzine mazita ne mabasa akasiyana asi Angori MWARI mumwe chete a VA"
    },
    {
      "verse": 55,
      "text": "Seku buda kwaita RA ☀️ mangwanani ano kudenga, Dai abudawo mu hana dzenyu maona"
    },
    {
      "verse": 56,
      "text": "Seku penya kwaita RA ☀️ kudenga , Dai apenyawo nema muri mangwanani ano"
    },
    {
      "verse": 57,
      "text": "RA ☀️ Dai abakawo ne matiri"
    },
    {
      "verse": 58,
      "text": "Kureva kuti , mukati memunhu ne munhu mune ZUVA ririmo"
    },
    {
      "verse": 59,
      "text": "Iri ZUVA i ZIVO"
    },
    {
      "verse": 60,
      "text": "Hautenderwe kuri dzima pose pose"
    },
    {
      "verse": 61,
      "text": "Iri zuva riri mumunhu rinonzi RA zvakare"
    },
    {
      "verse": 62,
      "text": "Ayo MAZUVA akataurwa na iye MOSES ,"
    },
    {
      "verse": 63,
      "text": "MAZUVA ekufa"
    },
    {
      "verse": 64,
      "text": "RA ☀️, Mazuva apera"
    },
    {
      "verse": 65,
      "text": "Moses akawana vanhu vachifa"
    },
    {
      "verse": 66,
      "text": "RA ☀️ Vaifa Mwari mavari"
    },
    {
      "verse": 67,
      "text": "Va ISRAEL vakanga vadzima ZUVA mavari"
    },
    {
      "verse": 68,
      "text": "Vakanga vadzima CHAEDZA cha MWARI mavari"
    },
    {
      "verse": 69,
      "text": "Moses wakauya kuzo dzima kufa RA kusina Mwari,"
    },
    {
      "verse": 70,
      "text": "Achiti ayewa taka tenderwa hedu kufa RA, asi kwete nekuda kwedu,"
    },
    {
      "verse": 71,
      "text": "RA anotifira oga"
    },
    {
      "verse": 72,
      "text": "Kwete kuti isu timu uraye nekuda kufa RA"
    },
    {
      "verse": 73,
      "text": "RA ☀️ Kunobva kuna Mwari"
    },
    {
      "verse": 74,
      "text": "Kusina kubva kuna Mwari"
    },
    {
      "verse": 75,
      "text": "Se rufu rwe munhu,"
    },
    {
      "verse": 76,
      "text": "Rufu chinhu chakabva kuna Mwari asi ku uraya hakutenderwe"
    },
    {
      "verse": 77,
      "text": "Kufara kwairambwa na EMOSES kwaiva kufa RA kuri kuda kwevanhu ne nzira dzaka rambidzwa"
    },
    {
      "verse": 78,
      "text": "Asi akati ibvai pamafaro enyika mutambire mufaro wekudenga"
    },
    {
      "verse": 79,
      "text": "Kwamuri vatendi"
    },
    {
      "verse": 80,
      "text": "Patinofara pose zivai kuti"
    },
    {
      "verse": 81,
      "text": "Zvinoitwa ne MUFIRI anenge abvuma kuti fira"
    },
    {
      "verse": 82,
      "text": "Saka hapana kufa RA ☀️ kana pasina"
    },
    {
      "verse": 83,
      "text": "RA ☀️ wacho wekufa"
    },
    {
      "verse": 84,
      "text": "Iiiiii sa ka"
    },
    {
      "verse": 85,
      "text": "RA ☀️ Kutaura"
    },
    {
      "verse": 86,
      "text": "Anofa achimuka zuva rega rega"
    },
    {
      "verse": 87,
      "text": "Achiti kana watambira INI, zvareva kuti newewo wava MUFA NDICHI MUKA"
    },
    {
      "verse": 88,
      "text": "Saka RA ndiye mufiri , kuda kana kusada,"
    },
    {
      "verse": 89,
      "text": "Kunyangwe vakati takamirira mufiri wedu asiri RA,"
    },
    {
      "verse": 90,
      "text": "Ngavazive kuti vasarudza kusazombofa vakafara"
    },
    {
      "verse": 91,
      "text": "RA ☀️ sei Ivo vasina"
    },
    {
      "verse": 92,
      "text": "RA ☀️ wekufa"
    },
    {
      "verse": 93,
      "text": "Ndo zvakapa ma JUDAH arambe akamirira JESU na nhasi"
    },
    {
      "verse": 94,
      "text": "Iye JESU akauya akaenda"
    },
    {
      "verse": 95,
      "text": "Vakatii hausiriwe"
    },
    {
      "verse": 96,
      "text": "Tine wedu akanzi ACHAUYA ne ropa"
    },
    {
      "verse": 97,
      "text": "Greek ALPHABET ndiro ropa"
    },
    {
      "verse": 98,
      "text": "Ndo paka buruka"
    },
    {
      "verse": 99,
      "text": "ALPHABET ye GREEK inovamba na"
    },
    {
      "verse": 100,
      "text": "Ichipera na"
    },
    {
      "verse": 101,
      "text": "Panouya MUTUMWA"
    },
    {
      "verse": 102,
      "text": "anongouya ne MUTAURO uno dzorera vanhu paku gona kutaura na MWARI achi vanzwa"
    },
    {
      "verse": 103,
      "text": "Tsvimbo yata pihwa parizvino mutauro unonzi"
    },
    {
      "verse": 104,
      "text": "Mutauro uyu watapihwa une mavara"
    },
    {
      "verse": 105,
      "text": "22 kutaura DNA ya MWARI."
    },
    {
      "verse": 106,
      "text": "Rekutanga rinonzi"
    },
    {
      "verse": 107,
      "text": "Mavambo, saka Mwari ndi ALEPH"
    },
    {
      "verse": 108,
      "text": "Vara reku pedzisira ndi"
    },
    {
      "verse": 109,
      "text": "Kureva kuti MWARI ndi TAV zvakare."
    },
    {
      "verse": 110,
      "text": "Ndiye MAVAMBO ne MAGUMO"
    },
    {
      "verse": 111,
      "text": "Vamwe vakaramba kutambira mutaura wa MOSES, kana kuti kutevera tsvimbo ya MOSES. ivavo ndo vakasara mu EGYPT"
    },
    {
      "verse": 112,
      "text": "Vaiti hameno zva ari kutaura zvana ALEPH nana TAV"
    },
    {
      "verse": 113,
      "text": "Mbiri imwe chete ya EMOSES yayazo dzoka futi Yava kuti ndini JESU"
    },
    {
      "verse": 114,
      "text": "Ndokusviko ona va ISRAEL vose vachiti ALEPH na TAV"
    },
    {
      "verse": 115,
      "text": "Ndokubva ati ko zvamakanga maramba wani"
    },
    {
      "verse": 116,
      "text": "Asi makazo sara muka tambira ndaenda"
    },
    {
      "verse": 117,
      "text": "Zvino kutambira kwenyu hakuverengwe, nekuti hamuna kutambira maka kopa"
    },
    {
      "verse": 118,
      "text": "Vakuru ve Israel vakabva vati Isu hatina kukopa ,"
    },
    {
      "verse": 119,
      "text": "Jesu akati kana musina ku kopa, regai tione kuti MUTAURO wandazo uya nawo nhasi muchautambira here"
    },
    {
      "verse": 120,
      "text": "Ndokubva ati"
    },
    {
      "verse": 121,
      "text": "ALPHABET ye GREEK iyooo"
    },
    {
      "verse": 122,
      "text": "Ndokubva ati"
    },
    {
      "verse": 123,
      "text": "Vakuru ve ISRAEL vakati wakudzima mutauro wa MOSES saka hatidi"
    },
    {
      "verse": 124,
      "text": "Jesu Ndoku taura, vadzidzi vachinyora ne GREEK"
    },
    {
      "verse": 125,
      "text": "Ikabva yanzi NEW TESTAMENT"
    },
    {
      "verse": 126,
      "text": "Iya yakanga ya nyorwa ne HEBREW na MOSES ne vadzidzi vake ikabva yanzi OLD TESTAMENT"
    },
    {
      "verse": 127,
      "text": "Jesu akati, hatidzime OLD TESTAMENT, asi tinoi dzidza tichiziva kuti ndo ya zuro"
    },
    {
      "verse": 128,
      "text": "Asi yanhasi ndiyo ino yata nyora ne GREEK"
    },
    {
      "verse": 129,
      "text": "Majudah akaramba Ye GREEK vakati tinongo tevera TORAH ye hebrew"
    },
    {
      "verse": 130,
      "text": "Zvino JESU oenda akati Nyika nda ipa NEW TESTAMENT , asi yose yaramba,"
    },
    {
      "verse": 131,
      "text": "Kusanganisira na PETER"
    },
    {
      "verse": 132,
      "text": "Hakuna akatambira IZWI ra JESU ari mupenyu"
    },
    {
      "verse": 133,
      "text": "Vashoma vakanga vasara vachitevera ndo vakazoti ahhh zvinhu izvi zvazvinenge zvisirizvo"
    },
    {
      "verse": 134,
      "text": "Ndokufa kwa JESU asina akamuda"
    },
    {
      "verse": 135,
      "text": "Asi akanga ava yambira"
    },
    {
      "verse": 136,
      "text": "Akati ndakuno fa Kuti imi muzogona kuti tafa"
    },
    {
      "verse": 137,
      "text": "RA ☀️ Zvediwo KUFA kwa Jesu kwakazounza Rufaro rwukuru vadzidzi vaona amuka"
    },
    {
      "verse": 138,
      "text": "Amuka mavari"
    },
    {
      "verse": 139,
      "text": "Zvino JESU akati pandichadzoka, munhu wese mukuru ne mudiki achange abata TSAMBA iyi yamaramba"
    },
    {
      "verse": 140,
      "text": "Zvediwo nhasi munhu wese ari kungoti JESU JESU"
    },
    {
      "verse": 141,
      "text": "Aripano JESU"
    },
    {
      "verse": 142,
      "text": "Ari apo JESU"
    },
    {
      "verse": 143,
      "text": "Neka NEW TESTAMENT muhomwe"
    },
    {
      "verse": 144,
      "text": "Kana driver we kombi, abenge ainako muhomwe"
    },
    {
      "verse": 145,
      "text": "Nhasi tombo verenga tsamba ra RUKA 17 Pa 25"
    },
    {
      "verse": 146,
      "text": "Vamwewo tombo verenga tsamba ra MATEO"
    },
    {
      "verse": 147,
      "text": "Maimana here matsamba aya munguva ya ainyorwa"
    },
    {
      "verse": 148,
      "text": "Ndo zvinoita munhu"
    },
    {
      "verse": 149,
      "text": "Chinzwai chinanara"
    },
    {
      "verse": 150,
      "text": "Pakapihwa pasi rose shoko ne GREEK ,"
    },
    {
      "verse": 151,
      "text": "JESU ainyora rimwe ne mutauro we kumba nekuti aisava mu greek"
    },
    {
      "verse": 152,
      "text": "Asi greek wakanga uri mutauro wainzwikwa ne marudzi"
    },
    {
      "verse": 153,
      "text": "Tinogona kunyora ne English kuti vanhu vakawanda vanzwe"
    },
    {
      "verse": 154,
      "text": "Nhau dze Matunhu matatu , dziri dze mumba"
    },
    {
      "verse": 155,
      "text": "Nekuti zvandiri kuita pano sandizvo zvandinoita ku MASOWE"
    },
    {
      "verse": 156,
      "text": "Izwi randino shandisa pano harina zera nezwi randino shandisa ku Masowe"
    },
    {
      "verse": 157,
      "text": "Jesu ane mashoko aaitaura musangano"
    },
    {
      "verse": 158,
      "text": "Iwawo hapana bible rinawo"
    },
    {
      "verse": 159,
      "text": "Iwawo ndo nzira"
    },
    {
      "verse": 160,
      "text": "Asi handisi kuti ekunze ahasi nzira"
    },
    {
      "verse": 161,
      "text": "Ndiri kuti aitaurwa murenje ndo MUTAMBO wa BABA uchatambwa"
    },
    {
      "verse": 162,
      "text": "Une ku muka kwe vakafa"
    },
    {
      "verse": 163,
      "text": "Iwayo Jesu aisati ndini Jesu kurenje"
    },
    {
      "verse": 164,
      "text": "Aiva asina Zita"
    },
    {
      "verse": 165,
      "text": "Nekuti mazita akanga asungwa na MWARI"
    },
    {
      "verse": 166,
      "text": "Mweya waivhunzwa kuti"
    },
    {
      "verse": 167,
      "text": "Nhai ishe , ndimi ani,"
    },
    {
      "verse": 168,
      "text": "Waipindura kuti"
    },
    {
      "verse": 169,
      "text": "Ehe ndini ANI"
    },
    {
      "verse": 170,
      "text": "Izvi zvaipa vanhu kutsvaga IDI kwete ZITA"
    },
    {
      "verse": 171,
      "text": "Nekuti IDI ringori IDI nyangwe ukariti GInatsio kana kuriti Satan"
    },
    {
      "verse": 172,
      "text": "Zvino vachena vakazvinzwa kuti vanhu vaya vaifamba na JESU vaka sirwa tsamba ravainaro"
    },
    {
      "verse": 173,
      "text": "Vakatii saka handei tinova torera, nekuti tanzwa kuti Jesu uya amuka asi ari kutaura ari mavari"
    },
    {
      "verse": 174,
      "text": "Ndokuurayiwa kwe vadzidzi 1 by 1"
    },
    {
      "verse": 175,
      "text": "Paitsvagwa Tsamba ra ANI"
    },
    {
      "verse": 176,
      "text": "Zvino matsamba mazhinji aka chererwa ku EGYPT ukoooo"
    },
    {
      "verse": 177,
      "text": "Nevadzidzi vachitiza"
    },
    {
      "verse": 178,
      "text": "Kuverengerawo nhoroondo ya judas"
    },
    {
      "verse": 179,
      "text": "Ya Maria magadalina"
    },
    {
      "verse": 180,
      "text": "Asi TSAMBA ra ANI chairo rakanga riri murenje"
    },
    {
      "verse": 181,
      "text": "Vakatozo riwana kwapfuura 1800 years Jesu Afa"
    },
    {
      "verse": 182,
      "text": "Ndo pavakati saka matsamba ese ana luke, mark, ne mamwe akanga asi riwo ataida kuba"
    },
    {
      "verse": 183,
      "text": "Vakabva vapera Simba"
    },
    {
      "verse": 184,
      "text": "Ndokutiii saka ma CATHEDRAL atavaka aya tanga tiri kuoedza nguva"
    },
    {
      "verse": 185,
      "text": "Nanhasi ma church avo akawanda asi hapana achaendako"
    },
    {
      "verse": 186,
      "text": "Ndokubva vati handei kuvanhu vaya tino tora tsamba ra ANI , tori viga"
    },
    {
      "verse": 187,
      "text": "Isu tova pinzawo muzvidziro"
    },
    {
      "verse": 188,
      "text": "Sezvatanga tava"
    },
    {
      "verse": 189,
      "text": "Chidziro chino sunga mafungiro"
    },
    {
      "verse": 190,
      "text": "Ndizvo JOHANI akati munhu wese kurenje"
    },
    {
      "verse": 191,
      "text": "Nekuti renje raka tambanuka"
    },
    {
      "verse": 192,
      "text": "Ne njere dzako dzino tambanuka"
    },
    {
      "verse": 193,
      "text": "Nekuti uka varairwa uri murenje, unogona kungo mutswa ne kuona Shiri iri yaka mhara pamuti , ototi a MWARI akasika zvinhu zvakanaka"
    },
    {
      "verse": 194,
      "text": "Asi muchidziro hamuna chino yeuchidza"
    },
    {
      "verse": 195,
      "text": "Vakabva vaveza zvifananidzo zveku yedza kuyeuchidza nazvo"
    },
    {
      "verse": 196,
      "text": "Kuti muite kanenge jahu MWARI"
    },
    {
      "verse": 197,
      "text": "Ayewa isu kumasowe pa ZAMBARA tika tarisa kudenga"
    },
    {
      "verse": 198,
      "text": "dzinenge dzichitoti Paridza hukuru hwa MWARI"
    },
    {
      "verse": 199,
      "text": "Dzichiti ARERUYA denga ririko"
    },
    {
      "verse": 200,
      "text": "Zvisinei ndaku pedza"
    },
    {
      "verse": 201,
      "text": "Tsamba ra ANI rakatorwa ne vachena vakaisa mu museum"
    },
    {
      "verse": 202,
      "text": "Se zvavakaita misoro yana NEHANDA"
    },
    {
      "verse": 203,
      "text": "Saka ini ndini ANI ndiri kutaura"
    },
    {
      "verse": 204,
      "text": "Vakariti TSAMBA re vakafa"
    },
    {
      "verse": 205,
      "text": "Iro riri tsamba rehupenyu"
    },
    {
      "verse": 206,
      "text": "Rakanyorwa ne SHONA"
    },
    {
      "verse": 207,
      "text": "Ndokurwadza kwazvo"
    },
    {
      "verse": 208,
      "text": "Kuti ANI ndo Shona"
    },
    {
      "verse": 209,
      "text": "Kuti ANI ndo zita ra MWARI ari muna ANI na ANI"
    },
    {
      "verse": 210,
      "text": "Nekuti Kuti ANI muvhunzo"
    },
    {
      "verse": 211,
      "text": "MWARI muvhunzo usati wawana Mhinduro"
    },
    {
      "verse": 212,
      "text": "Ndi ANI akasika nyika"
    },
    {
      "verse": 213,
      "text": "Ndi ANI akatuma MOSES"
    },
    {
      "verse": 214,
      "text": "Ndi ANI Baba va JESU"
    },
    {
      "verse": 215,
      "text": "Ndi ANI Mwari"
    },
    {
      "verse": 216,
      "text": "Iwe ndiwe ANI"
    },
    {
      "verse": 217,
      "text": "Ini ndini ANI"
    },
    {
      "verse": 218,
      "text": "Tose ndisu ANI"
    },
    {
      "verse": 219,
      "text": "Saka takubuda mu Egypt takati ANI na ANI na MUPOROFITA wema TATYA"
    },
    {
      "verse": 220,
      "text": "Nde mupi matakanga TATYA"
    },
    {
      "verse": 221,
      "text": "Mu ma PHAROAH enyika"
    },
    {
      "verse": 222,
      "text": "Ko muporofiti we ma TATYA ndi ani"
    },
    {
      "verse": 223,
      "text": "Ndiye EMOSES"
    },
    {
      "verse": 224,
      "text": "Akaisa matatya ku MAFARO enyika"
    },
    {
      "verse": 225,
      "text": "Nhasi ANI na ANI anotya kutadza"
    },
    {
      "verse": 226,
      "text": "Ndokuiswa kwe matatya kumafaro"
    },
    {
      "verse": 227,
      "text": "Sei MATATYA akanzi matatya,"
    },
    {
      "verse": 228,
      "text": "Nekuti anofamba hana ichi rova"
    },
    {
      "verse": 229,
      "text": "Ndikawana mukana ticha simudzira"
    },
    {
      "verse": 230,
      "text": "Kuzvika vose vaziva kuti Ndini ROVA MBIRA"
    },
    {
      "verse": 231,
      "text": "Tsvimbo ya EMOSES"
    },
    {
      "verse": 232,
      "text": "Ndatenda 🙏🏼☀️"
    }
  ]
}